        { "name": "PUT /api/pets/:id - Cập nhật thú cưng", "request": { "auth": { "type": "bearer" }, "method": "PUT", "url": "{{baseUrl}}/api/pets/REPLACE_WITH_ID", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"tenThuCung\": \"Mèo Mun - Updated\",\n  \"tuoi\": 3,\n  \"canNang\": 4.0\n}" }}},
        { "name": "DELETE /api/pets/:id - Xóa thú cưng", "request": { "auth": { "type": "bearer" }, "method": "DELETE", "url": "{{baseUrl}}/api/pets/REPLACE_WITH_ID" }}
      ]
    },


{
  "info": {
    "name": "SPATC Pet Shop API",
    "description": "RESTful API cho ứng dụng SPATC Pet Shop - Node.js/Express/MongoDB/JWT. Base URL: http://localhost:3000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },

  "item": [
    {
      "name": "🟢 AUTH - Xác thực",
      "item": [
        {
          "name": "POST /api/auth/register - Đăng ký",
          "event": [{ "listen": "test", "script": { "exec": ["var json = pm.response.json();", "if (json.data?.refreshToken) pm.collectionVariables.set('refreshToken', json.data.refreshToken);", "if (json.data?.accessToken) pm.collectionVariables.set('accessToken', json.data.accessToken);"] } }],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@spatc.vn\",\n  \"password\": \"Admin123!\",\n  \"hoTen\": \"Admin SPATC\",\n  \"vaiTro\": \"admin\"\n}" }
          }
        },
        {
          "name": "POST /api/auth/login - Đăng nhập",
          "event": [{ "listen": "test", "script": { "exec": ["var json = pm.response.json();", "if (json.data?.accessToken) pm.collectionVariables.set('accessToken', json.data.accessToken);", "if (json.data?.refreshToken) pm.collectionVariables.set('refreshToken', json.data.refreshToken);"] } }],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@spatc.vn\",\n  \"password\": \"Admin123!\"\n}" }
          }
        },
        {
          "name": "POST /api/auth/refresh - Làm mới token",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "GET /api/auth/me - Lấy thông tin user hiện tại",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET", "url": "{{baseUrl}}/api/auth/me"
          }
        },
        {
          "name": "POST /api/auth/logout - Đăng xuất",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/logout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        }
      ]
    },

    {
      "name": "🟢 ACCOUNTS - Tài khoản",
      "item": [
        { "name": "GET /api/accounts - Danh sách tài khoản", "request": { "auth": { "type": "bearer" }, "method": "GET", "url": "{{baseUrl}}/api/accounts" }},
        { "name": "POST /api/accounts - Tạo tài khoản", "request": { "auth": { "type": "bearer" }, "method": "POST", "url": "{{baseUrl}}/api/accounts", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"email\": \"nhanvien@spatc.vn\",\n  \"password\": \"Staff123!\",\n  \"hoTen\": \"Nguyễn Văn Nhân Viên\",\n  \"vaiTro\": \"nhanvien\"\n}" }}},
        { "name": "GET /api/accounts/:id - Chi tiết tài khoản", "request": { "auth": { "type": "bearer" }, "method": "GET", "url": "{{baseUrl}}/api/accounts/REPLACE_WITH_ID" }},
        { "name": "PUT /api/accounts/:id - Cập nhật tài khoản", "request": { "auth": { "type": "bearer" }, "method": "PUT", "url": "{{baseUrl}}/api/accounts/REPLACE_WITH_ID", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"hoTen\": \"Nguyễn Văn Nhân Viên - Updated\",\n  \"vaiTro\": \"nhanvien\"\n}" }}},
        { "name": "DELETE /api/accounts/:id - Xóa tài khoản", "request": { "auth": { "type": "bearer" }, "method": "DELETE", "url": "{{baseUrl}}/api/accounts/REPLACE_WITH_ID" }}
      ]
    },


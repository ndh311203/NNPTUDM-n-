@* Partial view để hiển thị gợi ý sản phẩm cho dịch vụ *@
<div id="productSuggestions" class="mt-5">
    <h3 class="mb-4">
        <i class="bi bi-cart-fill text-success"></i> Sản phẩm gợi ý cho bạn
    </h3>
    <div id="productSuggestionsContent" class="row g-4">
        <div class="col-12 text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Đang tải...</span>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const serviceId = @(ViewBag.ServiceId ?? 0);
        
        if (serviceId > 0) {
            loadProductSuggestions(serviceId);
        }
    });

    function loadProductSuggestions(serviceId) {
        fetch(`/Search/SuggestProductsForService?serviceId=${serviceId}&limit=6`)
            .then(response => response.json())
            .then(data => {
                if (data.success && data.suggestions && data.suggestions.length > 0) {
                    displayProductSuggestions(data.suggestions);
                } else {
                    document.getElementById('productSuggestions').style.display = 'none';
                }
            })
            .catch(error => {
                console.error('Error loading product suggestions:', error);
                document.getElementById('productSuggestions').style.display = 'none';
            });
    }

    function displayProductSuggestions(suggestions) {
        const container = document.getElementById('productSuggestionsContent');
        container.innerHTML = '';

        suggestions.forEach(product => {
            const productCard = `
                <div class="col-md-4 col-sm-6">
                    <div class="card h-100 shadow-sm">
                        ${product.image ? `
                            <img src="${product.image}" class="card-img-top" alt="${product.name}" style="height: 200px; object-fit: cover;">
                        ` : `
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
                            </div>
                        `}
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">${product.name}</h5>
                            <p class="card-text text-muted small">
                                <span class="badge bg-info">${product.category || product.type}</span>
                                ${product.brand ? `<span class="badge bg-secondary ms-1">${product.brand}</span>` : ''}
                            </p>
                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div>
                                        <h5 class="text-danger mb-0">${formatPrice(product.price)} đ</h5>
                                        ${product.oldPrice ? `<small class="text-muted text-decoration-line-through">${formatPrice(product.oldPrice)} đ</small>` : ''}
                                    </div>
                                    ${product.rating ? `
                                        <div>
                                            <span class="text-warning">${'★'.repeat(Math.floor(product.rating))}${'☆'.repeat(5 - Math.floor(product.rating))}</span>
                                            <small class="text-muted">(${product.rating.toFixed(1)})</small>
                                        </div>
                                    ` : ''}
                                </div>
                                <a href="/PetShop/${getProductTypeUrl(product.type)}Details/${product.id}" class="btn btn-outline-primary w-100">
                                    <i class="bi bi-eye"></i> Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            container.innerHTML += productCard;
        });
    }

    function getProductTypeUrl(type) {
        const typeMap = {
            'pet': 'Pet',
            'food': 'Food',
            'accessory': 'Accessory'
        };
        return typeMap[type] || 'Pet';
    }

    function formatPrice(price) {
        return new Intl.NumberFormat('vi-VN').format(price);
    }
</script>


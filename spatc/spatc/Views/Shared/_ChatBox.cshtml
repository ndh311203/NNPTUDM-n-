@if (User.Identity?.IsAuthenticated == true)
{
    <div id="chatBoxContainer" style="position: fixed; bottom: 20px; right: 20px; z-index: 1050;">
        <div id="chatBox" style="display: none; width: 350px; height: 500px; background: white; border-radius: 10px; box-shadow: 0 4px 20px rgba(0,0,0,0.15); flex-direction: column; overflow: hidden;">
            <div id="chatHeader" style="background: linear-gradient(135deg, #FFE5E5 0%, #FFD6D6 100%); padding: 15px; display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #ADD8E6;">
                <div>
                    <h6 style="margin: 0; color: #654321; font-weight: bold;">
                        <i class="bi bi-chat-dots"></i> Hỗ trợ khách hàng
                    </h6>
                    <small id="chatStatus" style="color: #654321;">Đang kết nối...</small>
                </div>
                <button id="chatMinimizeBtn" class="btn btn-sm" style="background: transparent; border: none; color: #654321;">
                    <i class="bi bi-dash"></i>
                </button>
            </div>
            <div id="chatBody" style="flex: 1; overflow-y: auto; padding: 15px; background: #f8f9fa;">
                <div id="chatMessages" style="display: flex; flex-direction: column; gap: 10px;">
                    <div class="text-center text-muted">
                        <small>Đang tải tin nhắn...</small>
                    </div>
                </div>
            </div>
            <div id="chatFooter" style="padding: 15px; border-top: 1px solid #dee2e6; background: white;">
                <div class="input-group">
                    <input type="text" id="chatInput" class="form-control" placeholder="Nhập tin nhắn..." style="border-color: #ADD8E6;">
                    <button id="chatSendBtn" class="btn btn-primary" style="background: linear-gradient(135deg, #FFE5E5 0%, #FFD6D6 100%); border: 1px solid #ADD8E6; color: #654321;">
                        <i class="bi bi-send"></i>
                    </button>
                </div>
            </div>
        </div>
        <button id="chatToggleBtn" class="btn btn-primary rounded-circle" style="width: 60px; height: 60px; background: linear-gradient(135deg, #FFE5E5 0%, #FFD6D6 100%); border: 2px solid #ADD8E6; color: #654321; box-shadow: 0 4px 15px rgba(0,0,0,0.2); position: relative;">
            <i class="bi bi-chat-dots" style="font-size: 24px;"></i>
            <span id="chatUnreadBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display: none;">0</span>
        </button>
    </div>
}


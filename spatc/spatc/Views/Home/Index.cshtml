@{
    ViewData["Title"] = "Trang chủ - Spa Thú Cưng";
    var dichVuNoiBat = ViewBag.DichVuNoiBat as List<spatc.Models.DichVu> ?? new List<spatc.Models.DichVu>();
    var bestSellingProducts = ViewBag.BestSellingProducts as List<spatc.Models.ProductDto> ?? new List<spatc.Models.ProductDto>();
    var activeVouchers = ViewBag.ActiveVouchers as List<spatc.Models.Voucher> ?? new List<spatc.Models.Voucher>();
    var recentReviews = ViewBag.RecentReviews as List<spatc.Models.ProductReview> ?? new List<spatc.Models.ProductReview>();
}

<style>
    /* ==========================================
       1️⃣ HERO SECTION – Banner chính
       ========================================== */
    .hero-section-wrapper {
        width: 100vw;
        position: relative;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
        margin-top: -24px;
        margin-bottom: 0;
        overflow-x: hidden;
    }
    
    .hero-section {
        background: linear-gradient(135deg, #FFE5E5 0%, #FFD6D6 50%, #FFCCCC 100%);
        padding: 100px 0;
        width: 100%;
        position: relative;
        overflow: hidden;
    }
    
    .hero-section::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 600px;
        height: 600px;
        background: rgba(173, 216, 230, 0.2);
        border-radius: 50%;
        z-index: 0;
    }
    
    .hero-section::after {
        content: '';
        position: absolute;
        bottom: -30%;
        left: -10%;
        width: 500px;
        height: 500px;
        background: rgba(173, 216, 230, 0.15);
        border-radius: 50%;
        z-index: 0;
    }
    
    /* Decorative icons */
    .hero-decoration {
        position: absolute;
        color: rgba(255, 255, 255, 0.4);
        z-index: 0;
        font-size: 3rem;
    }
    
    .hero-paw-1 {
        top: 15%;
        left: 10%;
        font-size: 2.5rem;
    }
    
    .hero-paw-2 {
        top: 25%;
        left: 5%;
        font-size: 2rem;
    }
    
    .hero-paw-3 {
        top: 35%;
        left: 12%;
        font-size: 1.8rem;
    }
    
    .hero-comb {
        top: 20%;
        left: 8%;
        font-size: 2rem;
    }
    
    .hero-paw-4 {
        top: 10%;
        right: 15%;
        font-size: 2.2rem;
    }
    
    .hero-paw-5 {
        top: 20%;
        right: 10%;
        font-size: 1.8rem;
    }
    
    .hero-bathtub {
        top: 5%;
        right: 8%;
        font-size: 2.5rem;
    }
    
    .hero-content {
        position: relative;
        z-index: 1;
    }
    
    .hero-title {
        font-size: 52px;
        font-weight: 800;
        line-height: 1.2;
        margin-bottom: 25px;
        color: #654321;
        text-shadow: 0 2px 10px rgba(255,255,255,0.5);
    }
    
    .hero-description {
        font-size: 20px;
        line-height: 1.7;
        margin-bottom: 35px;
        color: #8B4513;
        font-weight: 400;
    }
    
    .hero-btn {
        font-size: 18px;
        font-weight: 600;
        padding: 15px 40px;
        border-radius: 50px;
        background: linear-gradient(135deg, #ADD8E6 0%, #87CEEB 100%);
        color: #654321;
        box-shadow: 0 8px 20px rgba(173, 216, 230, 0.4);
        transition: all 0.3s ease;
        border: none;
    }
    
    .hero-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 30px rgba(173, 216, 230, 0.5);
        background: linear-gradient(135deg, #87CEEB 0%, #6BB6FF 100%);
        color: #654321;
    }
    
    .hero-image {
        position: relative;
        z-index: 1;
        border-radius: 20px;
        overflow: hidden;
    }
    
    .hero-image img {
        width: 100%;
        height: auto;
        border-radius: 20px;
        display: block;
        object-fit: cover;
        transition: transform 0.3s ease;
    }
    
    .hero-image:hover img {
        transform: scale(1.02);
    }
    
    /* ==========================================
       2️⃣ DỊCH VỤ NỔI BẬT (Featured Services)
       ========================================== */
    .service-section {
        padding: 80px 0;
        background: #ffffff;
    }
    
    .service-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        transition: all 0.4s ease;
        overflow: hidden;
        height: 100%;
        background: white;
    }
    
    .service-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 40px rgba(0,0,0,0.15);
    }
    
    .service-image {
        height: 220px;
        object-fit: cover;
        width: 100%;
        transition: transform 0.4s ease;
    }
    
    .service-card:hover .service-image {
        transform: scale(1.05);
    }
    
    .service-price {
        font-size: 24px;
        font-weight: 700;
        color: #ADD8E6;
    }
    
    .service-btn {
        border-radius: 25px;
        padding: 10px 25px;
        font-weight: 600;
        transition: all 0.3s ease;
    }
    
    /* ==========================================
       3️⃣ SẢN PHẨM BÁN CHẠY (Best-selling Products)
       ========================================== */
    .product-section {
        padding: 80px 0;
        background: #f8f9fa;
    }
    
    .product-card {
        border: 1px solid #e9ecef;
        border-radius: 15px;
        overflow: hidden;
        transition: all 0.3s ease;
        background: white;
        height: 100%;
    }
    
    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 35px rgba(173, 216, 230, 0.3);
        border-color: #ADD8E6;
    }
    
    .product-image-wrapper {
        position: relative;
        overflow: hidden;
        height: 240px;
        background: #f8f9fa;
    }
    
    .product-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
    }
    
    .product-card:hover .product-image {
        transform: scale(1.1);
    }
    
    .discount-badge {
        position: absolute;
        top: 12px;
        left: 12px;
        background: linear-gradient(135deg, #ee4d2d, #ff6b5a);
        color: white;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: bold;
        box-shadow: 0 3px 10px rgba(238, 77, 45, 0.3);
    }
    
    .product-price {
        font-size: 22px;
        font-weight: 700;
        color: #654321;
    }
    
    .product-old-price {
        font-size: 15px;
        color: #999;
        text-decoration: line-through;
    }
    
    /* ==========================================
       4️⃣ KHUYẾN MÃI / VOUCHER
       ========================================== */
    .voucher-section {
        padding: 80px 0;
        background: #ffffff;
    }
    
    .voucher-card {
        background: linear-gradient(135deg, #FFE5E5 0%, #FFD6D6 50%, #FFCCCC 100%);
        border: 3px dashed #ADD8E6;
        border-radius: 20px;
        padding: 35px;
        text-align: center;
        transition: all 0.4s ease;
        height: 100%;
        position: relative;
        overflow: hidden;
    }
    
    .voucher-card::before {
        content: '';
        position: absolute;
        top: -50px;
        right: -50px;
        width: 150px;
        height: 150px;
        background: rgba(173, 216, 230, 0.2);
        border-radius: 50%;
    }
    
    .voucher-card:hover {
        transform: translateY(-8px) scale(1.02);
        box-shadow: 0 15px 40px rgba(173, 216, 230, 0.3);
        border-color: #87CEEB;
    }
    
    .voucher-code {
        font-size: 28px;
        font-weight: 800;
        color: #654321;
        letter-spacing: 3px;
        margin-bottom: 20px;
        text-transform: uppercase;
        position: relative;
        z-index: 1;
    }
    
    .voucher-discount {
        font-size: 32px;
        font-weight: 800;
        color: #654321;
        margin-bottom: 15px;
    }
    
    .voucher-info {
        color: #666;
        font-size: 15px;
        margin-bottom: 8px;
        position: relative;
        z-index: 1;
    }
    
    /* ==========================================
       5️⃣ ĐÁNH GIÁ KHÁCH HÀNG (Customer Reviews)
       ========================================== */
    .review-section {
        padding: 80px 0;
        background: #f8f9fa;
    }
    
    .review-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.08);
        transition: all 0.4s ease;
        height: 100%;
        background: white;
    }
    
    .review-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 40px rgba(0,0,0,0.12);
    }
    
    .review-avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: linear-gradient(135deg, #ADD8E6, #87CEEB);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #654321;
        font-size: 32px;
        font-weight: bold;
        margin: 0 auto 20px;
        box-shadow: 0 5px 15px rgba(173, 216, 230, 0.4);
    }
    
    .review-stars {
        font-size: 20px;
        margin-bottom: 15px;
    }
    
    .review-text {
        font-style: italic;
        color: #555;
        line-height: 1.7;
        min-height: 90px;
    }
    
    /* ==========================================
       COMMON STYLES
       ========================================== */
    .section-title {
        font-size: 40px;
        font-weight: 800;
        color: #654321;
        margin-bottom: 15px;
        text-align: center;
    }
    
    .section-subtitle {
        font-size: 18px;
        color: #8B4513;
        margin-bottom: 50px;
        text-align: center;
    }
    
    .empty-state {
        padding: 80px 20px;
        text-align: center;
        color: #8B4513;
    }
    
    .empty-state-icon {
        font-size: 80px;
        margin-bottom: 25px;
        opacity: 0.6;
    }
    
    .empty-state h4 {
        font-size: 24px;
        margin-bottom: 15px;
        color: #654321;
    }
    
    .empty-state p {
        font-size: 16px;
        color: #8B4513;
    }
    
    /* ==========================================
       RESPONSIVE DESIGN
       ========================================== */
    @@media (max-width: 768px) {
        .hero-section {
            padding: 60px 0;
        }
        
        .hero-title {
            font-size: 36px;
        }
        
        .hero-description {
            font-size: 16px;
        }
        
        .section-title {
            font-size: 32px;
        }
        
        .service-section,
        .product-section,
        .voucher-section,
        .review-section {
            padding: 50px 0;
        }
        
        .hero-btn {
            font-size: 16px;
            padding: 12px 30px;
        }
    }
    
    @@media (max-width: 576px) {
        .hero-title {
            font-size: 28px;
        }
        
        .section-title {
            font-size: 28px;
        }
    }
</style>

<!-- 1️⃣ HERO SECTION – Banner chính -->
<div class="hero-section-wrapper">
    <section class="hero-section">
        <!-- Decorative icons -->
        <span class="hero-decoration hero-paw-1">🐾</span>
        <span class="hero-decoration hero-paw-2">🐾</span>
        <span class="hero-decoration hero-paw-3">🐾</span>
        <span class="hero-decoration hero-comb">✂️</span>
        <span class="hero-decoration hero-paw-4">🐾</span>
        <span class="hero-decoration hero-paw-5">🐾</span>
        <span class="hero-decoration hero-bathtub">🛁</span>
        
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6 hero-content">
                    <h1 class="hero-title">SPA THÚ CƯNG</h1>
                    <h2 class="hero-title" style="font-size: 36px; margin-top: -10px; margin-bottom: 20px;">CHĂM SÓC & LÀM ĐẸP</h2>
                    <p class="hero-description">
                        Chăm sóc thú cưng của bạn với dịch vụ spa cao cấp, không gian hiện đại và đội ngũ chuyên nghiệp. 
                        Mang đến sự thoải mái và hạnh phúc cho người bạn bốn chân của bạn.
                    </p>
                    <a href="/DatLich" class="btn hero-btn">
                        <i class="bi bi-calendar-check me-2"></i> Đặt lịch ngay
                    </a>
                </div>
                <div class="col-lg-6 hero-image mt-4 mt-lg-0">
                    <img src="/images/poster.jpg" 
                         alt="Poster Spa Thú Cưng - Chăm sóc & Làm đẹp" 
                         class="img-fluid rounded" 
                         style="box-shadow: 0 10px 30px rgba(173, 216, 230, 0.3); border: 3px solid rgba(255, 255, 255, 0.5);"
                         onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1548199973-03cce0bbc87b?w=800&h=600&fit=crop&q=80';">
                </div>
            </div>
        </div>
    </section>
</div>

<!-- 2️⃣ DỊCH VỤ NỔI BẬT (Featured Services) -->
<section class="service-section">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Dịch vụ nổi bật</h2>
            <p class="section-subtitle">Các dịch vụ spa được yêu thích nhất</p>
        </div>
        
        <div class="row g-4">
            @if (dichVuNoiBat.Any())
            {
                @foreach (var dv in dichVuNoiBat.Take(6))
                {
                    <div class="col-lg-4 col-md-6">
                        <div class="card service-card">
                            @if (!string.IsNullOrEmpty(dv.HinhAnh))
                            {
                                <img src="@dv.HinhAnh" class="service-image" alt="@dv.TenDichVu" 
                                     onerror="this.src='https://via.placeholder.com/400x220/f0f0f0/999999?text=Dịch+vụ'; this.onerror=null;">
                            }
                            else
                            {
                                <img src="https://via.placeholder.com/400x220/f0f0f0/999999?text=Dịch+vụ" class="service-image" alt="@dv.TenDichVu">
                            }
                            <div class="card-body p-4">
                                <h5 class="card-title fw-bold mb-3" style="font-size: 20px; color: #654321;">@dv.TenDichVu</h5>
                                <p class="card-text text-muted mb-3" style="min-height: 70px; font-size: 15px; line-height: 1.6;">
                                    @(dv.MoTa?.Length > 120 ? dv.MoTa.Substring(0, 120) + "..." : dv.MoTa ?? "Dịch vụ chăm sóc thú cưng chuyên nghiệp với không gian hiện đại và đội ngũ giàu kinh nghiệm.")
                                </p>
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="service-price">@dv.Gia.ToString("N0") đ</span>
                                </div>
                                <a href="@Url.Action("Details", "DichVu", new { id = dv.Id })" class="btn btn-primary service-btn w-100" style="color: #654321 !important;">
                                    <i class="bi bi-eye me-2"></i>Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="empty-state">
                        <div class="empty-state-icon">🐾</div>
                        <h4>Chưa có dịch vụ nào</h4>
                        <p>Các dịch vụ đang được cập nhật. Vui lòng quay lại sau!</p>
                    </div>
                </div>
            }
        </div>
        
        @if (dichVuNoiBat.Any())
        {
            <div class="text-center mt-5">
                <a href="/DichVu" class="btn btn-primary btn-lg px-5 rounded-pill" style="color: #654321 !important;">
                    <i class="bi bi-grid me-2"></i>Xem tất cả dịch vụ
                </a>
            </div>
        }
    </div>
</section>

<!-- 3️⃣ SẢN PHẨM BÁN CHẠY (Best-selling Products) -->
<section class="product-section">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Sản phẩm bán chạy</h2>
            <p class="section-subtitle">Những sản phẩm được yêu thích nhất</p>
        </div>
        
        <div class="row g-4">
            @if (bestSellingProducts.Any())
            {
                @foreach (var product in bestSellingProducts.Take(6))
                {
                    var discount = product.OldPrice != null && product.OldPrice > product.Price 
                        ? Math.Round((1 - (double)product.Price / (double)product.OldPrice) * 100) 
                        : 0;
                    
                    var detailUrl = product.Type == "pet" 
                        ? Url.Action("PetDetails", "PetShop", new { id = product.Id })
                        : product.Type == "food"
                        ? Url.Action("FoodDetails", "PetShop", new { id = product.Id })
                        : Url.Action("AccessoryDetails", "PetShop", new { id = product.Id });
                    
                    <div class="col-lg-3 col-md-6">
                        <div class="product-card">
                            <a href="@detailUrl" style="text-decoration: none; color: inherit;">
                                <div class="product-image-wrapper">
                                    <img src="@(product.Image ?? "/images/placeholder.jpg")" 
                                         alt="@product.Name" 
                                         class="product-image"
                                         onerror="this.src='https://via.placeholder.com/300x240/f0f0f0/999999?text=Sản+phẩm'; this.onerror=null;">
                                    @if (discount > 0)
                                    {
                                        <div class="discount-badge">-@discount%</div>
                                    }
                                </div>
                                <div class="card-body p-3">
                                    <h6 class="card-title mb-2" style="font-size: 16px; font-weight: 600; min-height: 48px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4; color: #654321;">
                                        @product.Name
                                    </h6>
                                    <div class="mb-2">
                                        <span class="product-price">@product.Price.ToString("N0") đ</span>
                                        @if (product.OldPrice != null && product.OldPrice > product.Price)
                                        {
                                            <span class="product-old-price ms-2">@product.OldPrice.Value.ToString("N0") đ</span>
                                        }
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between mb-3">
                                        <div>
                                            @{
                                                var rating = (double)product.Rating;
                                                var fullStars = (int)Math.Floor(rating);
                                            }
                                            @for (int i = 0; i < 5; i++)
                                            {
                                                if (i < fullStars)
                                                {
                                                    <span style="color: #ffc107; font-size: 14px;">★</span>
                                                }
                                                else
                                                {
                                                    <span style="color: #ddd; font-size: 14px;">★</span>
                                                }
                                            }
                                        </div>
                                        <small class="text-muted">Đã bán: @product.SoldCount</small>
                                    </div>
                                    <a href="@detailUrl" class="btn btn-outline-primary w-100 rounded-pill btn-sm" style="border-color: #ADD8E6; color: #654321;">
                                        <i class="bi bi-eye me-1"></i>Xem chi tiết
                                    </a>
                                </div>
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="empty-state">
                        <div class="empty-state-icon">🛍️</div>
                        <h4>Chưa có sản phẩm nào</h4>
                        <p>Sản phẩm đang được cập nhật. Vui lòng quay lại sau!</p>
                    </div>
                </div>
            }
        </div>
        
        @if (bestSellingProducts.Any())
        {
            <div class="text-center mt-5">
                                    <a href="@Url.Action("Shop", "PetShop")" class="btn btn-primary btn-lg px-5 rounded-pill" style="color: #654321 !important;">
                                        <i class="bi bi-shop me-2"></i>Xem tất cả sản phẩm
                                    </a>
            </div>
        }
    </div>
</section>

<!-- 4️⃣ KHUYẾN MÃI / VOUCHER -->
<section class="voucher-section">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Khuyến mãi hiện tại</h2>
            <p class="section-subtitle">Ưu đãi đặc biệt dành cho bạn</p>
        </div>
        
        <div class="row g-4">
            @if (activeVouchers.Any())
            {
                @foreach (var voucher in activeVouchers.Take(3))
                {
                    <div class="col-lg-4 col-md-6">
                        <div class="voucher-card">
                            <div class="voucher-code">@voucher.Code</div>
                            <div class="voucher-discount">
                                @if (voucher.Type == "percent")
                                {
                                    <text>Giảm @voucher.Value%</text>
                                }
                                else
                                {
                                    <text>Giảm @voucher.Value.ToString("N0") đ</text>
                                }
                            </div>
                            <p class="voucher-info">
                                <i class="bi bi-cart-check me-2"></i>
                                Đơn tối thiểu: <strong>@voucher.MinOrderAmount.ToString("N0") đ</strong>
                            </p>
                            <p class="voucher-info mb-0">
                                <i class="bi bi-calendar-event me-2"></i>
                                Thời hạn: <strong>@voucher.EndDate.ToString("dd/MM/yyyy")</strong>
                            </p>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="empty-state">
                        <div class="empty-state-icon">🎁</div>
                        <h4>Hiện chưa có khuyến mãi</h4>
                        <p>Vui lòng quay lại sau để nhận ưu đãi mới!</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- 5️⃣ ĐÁNH GIÁ KHÁCH HÀNG (Customer Reviews) -->
<section class="review-section">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Khách hàng nói gì?</h2>
            <p class="section-subtitle">Những đánh giá thực tế từ khách hàng của chúng tôi</p>
        </div>
        
        <div class="row g-4">
            @if (recentReviews.Any())
            {
                @foreach (var review in recentReviews.Take(5))
                {
                    <div class="col-lg-4 col-md-6">
                        <div class="card review-card">
                            <div class="card-body p-4 text-center">
                                <div class="review-avatar">
                                    @review.CustomerName.Substring(0, 1).ToUpper()
                                </div>
                                <h6 class="fw-bold mb-2" style="font-size: 18px; color: #654321;">@review.CustomerName</h6>
                                <div class="review-stars mb-3">
                                    @for (int i = 0; i < 5; i++)
                                    {
                                        if (i < review.Rating)
                                        {
                                            <span class="text-warning">★</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">★</span>
                                        }
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(review.Comment))
                                {
                                    <p class="review-text mb-3">
                                        "@(review.Comment.Length > 150 ? review.Comment.Substring(0, 150) + "..." : review.Comment)"
                                    </p>
                                }
                                else
                                {
                                    <p class="review-text mb-3">
                                        Khách hàng đã đánh giá @review.Rating sao cho sản phẩm/dịch vụ này.
                                    </p>
                                }
                                <small class="text-muted">
                                    <i class="bi bi-calendar me-1"></i>@review.CreatedAt.ToString("dd/MM/yyyy")
                                </small>
                                @if (!string.IsNullOrEmpty(review.Images))
                                {
                                    var images = review.Images.Split(',', StringSplitOptions.RemoveEmptyEntries);
                                    if (images.Length > 0)
                                    {
                                        <div class="mt-3">
                                            <img src="@images[0].Trim()" alt="Review" class="img-thumbnail rounded" 
                                                 style="width: 90px; height: 90px; object-fit: cover;" 
                                                 onerror="this.style.display='none'">
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="empty-state">
                        <div class="empty-state-icon">💬</div>
                        <h4>Chưa có đánh giá nào</h4>
                        <p>Hãy là người đầu tiên đánh giá dịch vụ của chúng tôi!</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>


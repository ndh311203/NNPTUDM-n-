@{
    ViewData["Title"] = "Liên hệ";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Liên hệ với chúng tôi</h1>
        <p class="lead text-muted">Chúng tôi luôn sẵn sàng hỗ trợ bạn</p>
    </div>

    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="card h-100 shadow">
                <div class="card-body">
                    <h3 class="card-title mb-4">Thông tin liên hệ</h3>
                    <div class="mb-3">
                        <h5><i class="bi bi-geo-alt-fill text-primary"></i> Địa chỉ</h5>
                        <p>@ViewBag.DiaChi</p>
                    </div>
                    <div class="mb-3">
                        <h5><i class="bi bi-telephone-fill text-primary"></i> Hotline</h5>
                        <p><a href="tel:@ViewBag.Hotline" class="text-decoration-none">@ViewBag.Hotline</a></p>
                    </div>
                    <div class="mb-3">
                        <h5><i class="bi bi-envelope-fill text-primary"></i> Email</h5>
                        <p><a href="mailto:@ViewBag.Email" class="text-decoration-none">@ViewBag.Email</a></p>
                    </div>
                    <div class="mb-3">
                        <h5><i class="bi bi-clock-fill text-primary"></i> Giờ làm việc</h5>
                        <p>@ViewBag.GioLamViec</p>
                    </div>
                    <div class="mb-3">
                        <h5><i class="bi bi-chat-dots-fill text-primary"></i> Zalo</h5>
                        <p><a href="https://zalo.me/@ViewBag.Zalo" target="_blank" class="text-decoration-none">@ViewBag.Zalo</a></p>
                    </div>
                    <div class="mb-3">
                        <h5><i class="bi bi-facebook text-primary"></i> Facebook</h5>
                        <p><a href="@ViewBag.Facebook" target="_blank" class="text-decoration-none">Facebook của chúng tôi</a></p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6 mb-4">
            <div class="card h-100 shadow">
                <div class="card-body">
                    <h3 class="card-title mb-4">Bản đồ</h3>
                    <div style="width: 100%; height: 400px; background: #f0f0f0; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                        <iframe 
                            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.1234567890123!2d106.6297!3d10.8231!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTDCsDQ5JzIzLjEiTiAxMDbCsDM3JzQ2LjkiRQ!5e0!3m2!1svi!2s!4v1234567890123!5m2!1svi!2s" 
                            width="100%" 
                            height="100%" 
                            style="border:0; border-radius: 8px;" 
                            allowfullscreen="" 
                            loading="lazy">
                        </iframe>
                    </div>
                    <p class="text-muted mt-3"><small>Bản đồ chỉ mang tính chất minh họa</small></p>
                </div>
            </div>
        </div>
    </div>
</div>


@model spatc.Models.ThuCung
@{
    ViewData["Title"] = "Chỉnh sửa thú cưng";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0"><i class="bi bi-pencil"></i> Chỉnh sửa thông tin thú cưng</h4>
                </div>
                <div class="card-body">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            @ViewBag.Error
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        
                        <div class="mb-3">
                            <label for="tenThuCung" class="form-label">Tên thú cưng *</label>
                            <input type="text" class="form-control" id="tenThuCung" name="tenThuCung" 
                                   value="@Model.TenThuCung" required>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="loai" class="form-label">Loại *</label>
                                    <select class="form-select" id="loai" name="loai" required>
                                        <option value="">-- Chọn loại --</option>
                                        <option value="Chó" selected="@(Model.Loai == "Chó")">🐕 Chó</option>
                                        <option value="Mèo" selected="@(Model.Loai == "Mèo")">🐱 Mèo</option>
                                        <option value="Hamster" selected="@(Model.Loai == "Hamster")">🐹 Hamster</option>
                                        <option value="Thỏ" selected="@(Model.Loai == "Thỏ")">🐰 Thỏ</option>
                                        <option value="Chim" selected="@(Model.Loai == "Chim")">🐦 Chim</option>
                                        <option value="Khác" selected="@(Model.Loai == "Khác")">Khác</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="giong" class="form-label">Giống</label>
                                    <input type="text" class="form-control" id="giong" name="giong" 
                                           value="@Model.Giong" placeholder="Ví dụ: Golden Retriever, Persian">
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="tuoi" class="form-label">Tuổi (tháng)</label>
                                    <input type="number" class="form-control" id="tuoi" name="tuoi" 
                                           value="@Model.Tuoi" min="0">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="canNang" class="form-label">Cân nặng (kg)</label>
                                    <input type="number" class="form-control" id="canNang" name="canNang" 
                                           value="@Model.CanNang" step="0.01" min="0">
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="ghiChuSucKhoe" class="form-label">Ghi chú sức khỏe</label>
                            <textarea class="form-control" id="ghiChuSucKhoe" name="ghiChuSucKhoe" rows="3">@Model.GhiChuSucKhoe</textarea>
                        </div>

                        <div class="mb-3">
                            <label for="hinhAnh" class="form-label">URL Hình ảnh</label>
                            <input type="url" class="form-control" id="hinhAnh" name="hinhAnh" 
                                   value="@Model.HinhAnh" placeholder="https://...">
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-check-circle"></i> Lưu thay đổi
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-secondary">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


@model IEnumerable<spatc.Models.ThuCung>
@{
    ViewData["Title"] = "Quản lý thú cưng của tôi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-heart"></i> Thú cưng của tôi</h2>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Thêm thú cưng mới
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Bạn chưa có thú cưng nào. <a href="@Url.Action("Create")">Thêm thú cưng ngay</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm h-100">
                        @if (!string.IsNullOrEmpty(item.HinhAnh))
                        {
                            <img src="@item.HinhAnh" class="card-img-top" alt="@item.TenThuCung" style="height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                <i class="bi bi-image" style="font-size: 3rem; color: #ccc;"></i>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title">@item.TenThuCung</h5>
                            <p class="card-text">
                                <strong>Loại:</strong> @item.Loai<br>
                                @if (!string.IsNullOrEmpty(item.Giong))
                                {
                                    <strong>Giống:</strong> @item.Giong<br>
                                }
                                @if (item.Tuoi.HasValue)
                                {
                                    <strong>Tuổi:</strong> @(item.Tuoi.Value + " tháng")<br>
                                }
                                @if (item.CanNang.HasValue)
                                {
                                    <strong>Cân nặng:</strong> @(item.CanNang.Value + " kg")
                                }
                            </p>
                        </div>
                        <div class="card-footer bg-white">
                            <div class="btn-group w-100" role="group">
                                <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil"></i> Sửa
                                </a>
                                <a href="@Url.Action("Delete", new { id = item.Id })" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Xóa
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="mt-3">
        <a href="@Url.Action("Profile", "Account")" class="btn btn-link">← Về thông tin tài khoản</a>
    </div>
</div>


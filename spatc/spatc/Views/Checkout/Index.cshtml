@{
    ViewData["Title"] = "Thanh toán";
    var qrInfo = ViewBag.VietQRInfo as spatc.Services.VietQRInfo;
}

<div class="container mt-4">
    <h2 class="mb-4">💳 Thanh toán</h2>

    <div id="checkoutEmpty" class="alert alert-warning text-center" style="display: none;">
        <h4>Giỏ hàng trống</h4>
        <p>Bạn cần có sản phẩm trong giỏ hàng để thanh toán.</p>
        <a href="@Url.Action("Index", "Cart")" class="btn btn-primary">Quay lại giỏ hàng</a>
    </div>

    <div id="checkoutContent" style="display: none;">
        <form id="checkoutForm">
            <div class="row">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Thông tin khách hàng</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">Họ tên *</label>
                                <input type="text" class="form-control" id="customerName" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Số điện thoại *</label>
                                <input type="tel" class="form-control" id="phone" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" id="email">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Địa chỉ *</label>
                                <textarea class="form-control" id="address" rows="3" required></textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Ghi chú</label>
                                <textarea class="form-control" id="note" rows="3"></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Đơn hàng của bạn</h5>
                        </div>
                        <div class="card-body">
                            <div id="checkoutItems">
                                <!-- Order items will be loaded here by JavaScript -->
                            </div>
                            <hr>
                            
                            <!-- Voucher Section -->
                            <div class="mb-3">
                                <label class="form-label">Mã giảm giá</label>
                                <div class="input-group">
                                    <input type="text" class="form-control" id="voucherCode" placeholder="Nhập mã voucher">
                                    <button class="btn btn-outline-primary" type="button" id="applyVoucherBtn">Áp dụng</button>
                                </div>
                                <div id="voucherMessage" class="mt-2"></div>
                            </div>

                            <div class="d-flex justify-content-between mb-2">
                                <span>Tạm tính:</span>
                                <span id="checkoutSubtotal">0 đ</span>
                            </div>
                            <div id="discountRow" class="d-flex justify-content-between mb-2 text-success" style="display: none;">
                                <span>Giảm giá:</span>
                                <span id="discountAmount">0 đ</span>
                            </div>
                            <div class="d-flex justify-content-between mb-3">
                                <strong>Tổng tiền:</strong>
                                <strong class="text-primary fs-5" id="checkoutTotal">0 đ</strong>
                            </div>
                        </div>
                    </div>

                    <div class="card mt-3">
                        <div class="card-header">
                            <h5 class="mb-0">Phương thức thanh toán</h5>
                        </div>
                        <div class="card-body">
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="radio" name="paymentMethod" id="paymentCOD" value="COD" checked>
                                <label class="form-check-label" for="paymentCOD">
                                    💵 Thanh toán khi nhận hàng (COD)
                                </label>
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="radio" name="paymentMethod" id="paymentVietQR" value="VietQR">
                                <label class="form-check-label" for="paymentVietQR">
                                    📱 Thanh toán VietQR
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="paymentMethod" id="paymentBank" value="BankTransfer">
                                <label class="form-check-label" for="paymentBank">
                                    🏦 Chuyển khoản ngân hàng
                                </label>
                            </div>
                            
                            <!-- Bank Transfer Info -->
                            <div id="bankInfo" style="display: none;" class="mt-3 p-3 bg-light rounded">
                                <p class="mb-2"><strong>Thông tin chuyển khoản:</strong></p>
                                @if (qrInfo != null)
                                {
                                    <p class="mb-1">Số tài khoản: <strong>@qrInfo.AccountNumber</strong></p>
                                    <p class="mb-1">Ngân hàng: <strong>@qrInfo.BankName</strong></p>
                                    <p class="mb-0">Chủ tài khoản: <strong>@qrInfo.AccountName</strong></p>
                                    <p class="mb-0 mt-2"><small class="text-muted">Nội dung: Mã đơn hàng của bạn</small></p>
                                }
                            </div>

                            <!-- VietQR Section -->
                            <div id="vietQRSection" style="display: none;" class="mt-3">
                                <div class="card border-primary">
                                    <div class="card-body text-center p-4" style="background: linear-gradient(135deg, #e3f2fd 0%, #ffffff 100%);">
                                        @if (qrInfo != null)
                                        {
                                            <!-- Header với logo và thông tin -->
                                            <div class="mb-3">
                                                <div class="d-flex align-items-center justify-content-center mb-2">
                                                    <div class="text-primary" style="font-size: 1.5rem; font-weight: bold;">⭐</div>
                                                    <h5 class="mb-0 ms-2 text-primary">@qrInfo.AccountName</h5>
                                                </div>
                                                <p class="mb-0 text-dark fw-bold" style="font-size: 1.1rem;">@qrInfo.AccountNumber</p>
                                            </div>
                                            
                                            <!-- QR Code Container -->
                                            <div class="mb-3">
                                                <div id="qrCodeContainer" class="d-inline-block p-3 bg-white rounded shadow-sm"></div>
                                            </div>
                                            
                                            <!-- Footer với logo VietQR và napas -->
                                            <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                                                <div class="text-start">
                                                    <div class="d-flex align-items-center">
                                                        <span class="text-danger fw-bold" style="font-size: 1.2rem;">V</span>
                                                        <span class="text-dark fw-bold ms-1">IETQR</span>
                                                    </div>
                                                </div>
                                                <div class="text-end">
                                                    <div class="d-flex align-items-center">
                                                        <span class="text-primary" style="font-size: 0.9rem; font-weight: 500;">napas</span>
                                                        <span class="text-success ms-1" style="font-size: 1rem; font-weight: bold;">247</span>
                                                    </div>
                                                </div>
                                            </div>
                                            
                                            <!-- Thông tin chi tiết -->
                                            <div class="mt-3 p-3 bg-white rounded">
                                                <p class="mb-2"><strong>Thông tin chuyển khoản:</strong></p>
                                                <p class="mb-1 small">Ngân hàng: <strong>@qrInfo.BankName</strong></p>
                                                <p class="mb-1 small">Số tài khoản: <strong>@qrInfo.AccountNumber</strong></p>
                                                <p class="mb-1 small">Chủ tài khoản: <strong>@qrInfo.AccountName</strong></p>
                                                <p class="mb-0 small">Nội dung CK: <strong id="transferContent" class="text-primary">-</strong></p>
                                                <p class="mb-0 mt-2 small"><strong id="qrTotalAmount" class="text-danger">0 đ</strong></p>
                                            </div>
                                            
                                            <!-- Action buttons -->
                                            <div class="mt-3">
                                                <button type="button" class="btn btn-sm btn-outline-primary me-2" id="copyContentBtn">
                                                    <i class="bi bi-clipboard"></i> Copy nội dung
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-success" id="downloadQRBtn">
                                                    <i class="bi bi-download"></i> Tải QR
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div class="alert alert-info mt-3">
                                    <small><i class="bi bi-info-circle"></i> Quét QR code bằng ứng dụng ngân hàng để thanh toán nhanh chóng. Sau khi chuyển khoản, đơn hàng sẽ được xác nhận thủ công.</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid mt-3">
                        <button type="submit" class="btn btn-primary btn-lg" id="placeOrderBtn">
                            <i class="bi bi-check-circle"></i> Đặt hàng
                        </button>
                        <a href="@Url.Action("Index", "Cart")" class="btn btn-outline-secondary mt-2">
                            <i class="bi bi-arrow-left"></i> Quay lại giỏ hàng
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/cart.js"></script>
    <script>
        let currentSubtotal = 0;
        let currentDiscount = 0;
        let appliedVoucherCode = null;
        let qrCodeDataUrl = null;
        let transferContentValue = null;

        document.addEventListener('DOMContentLoaded', function() {
            // Payment method change handler
            document.querySelectorAll('input[name="paymentMethod"]').forEach(radio => {
                radio.addEventListener('change', function() {
                    document.getElementById('bankInfo').style.display = 
                        this.value === 'BankTransfer' ? 'block' : 'none';
                    
                    // Chỉ hiển thị VietQR section nếu đã có QR code (sau khi đặt hàng)
                    if (this.value === 'VietQR' && qrCodeDataUrl) {
                        document.getElementById('vietQRSection').style.display = 'block';
                    } else if (this.value !== 'VietQR') {
                        document.getElementById('vietQRSection').style.display = 'none';
                    }
                });
            });

            // Voucher apply button
            document.getElementById('applyVoucherBtn').addEventListener('click', applyVoucher);

            // Copy content button
            document.getElementById('copyContentBtn').addEventListener('click', function() {
                if (transferContentValue) {
                    navigator.clipboard.writeText(transferContentValue).then(() => {
                        alert('Đã copy nội dung chuyển khoản!');
                    });
                }
            });

            // Download QR button
            document.getElementById('downloadQRBtn').addEventListener('click', function() {
                if (qrCodeDataUrl) {
                    // Convert data URL to blob and download
                    fetch(qrCodeDataUrl)
                        .then(res => res.blob())
                        .then(blob => {
                            const url = window.URL.createObjectURL(blob);
                            const link = document.createElement('a');
                            link.href = url;
                            link.download = `vietqr-order-${new Date().getTime()}.png`;
                            document.body.appendChild(link);
                            link.click();
                            document.body.removeChild(link);
                            window.URL.revokeObjectURL(url);
                        })
                        .catch(err => {
                            console.error('Error downloading QR:', err);
                            alert('Không thể tải QR code. Vui lòng thử lại.');
                        });
                } else {
                    alert('QR code chưa được tạo. Vui lòng đặt hàng trước.');
                }
            });

            // Load cart items
            loadCheckoutCart();

            // Handle form submission
            document.getElementById('checkoutForm').addEventListener('submit', async function(e) {
                e.preventDefault();
                await placeOrder();
            });
        });

        async function loadCheckoutCart() {
            const cart = getCart();
            if (!cart || cart.length === 0) {
                document.getElementById('checkoutEmpty').style.display = 'block';
                document.getElementById('checkoutContent').style.display = 'none';
                return;
            }

            document.getElementById('checkoutEmpty').style.display = 'none';
            document.getElementById('checkoutContent').style.display = 'block';

            let html = '';
            let subtotal = 0;

            for (const item of cart) {
                const productInfo = await getProductInfo(item.productId, item.productType);
                if (productInfo.success) {
                    const itemTotal = productInfo.product.price * item.quantity;
                    subtotal += itemTotal;

                    html += `
                        <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                            <div class="d-flex align-items-center">
                                ${productInfo.image ? `<img src="${productInfo.image}" class="me-3" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;">` : ''}
                                <div>
                                    <strong>${productInfo.product.name}</strong>
                                    <div class="text-muted small">Số lượng: ${item.quantity}</div>
                                </div>
                            </div>
                            <div class="text-end">
                                <strong>${formatPrice(itemTotal)} đ</strong>
                            </div>
                        </div>
                    `;
                }
            }

            currentSubtotal = subtotal;
            document.getElementById('checkoutItems').innerHTML = html;
            updateTotals();
        }

        function updateTotals() {
            const finalAmount = currentSubtotal - currentDiscount;
            document.getElementById('checkoutSubtotal').textContent = formatPrice(currentSubtotal) + ' đ';
            
            if (currentDiscount > 0) {
                document.getElementById('discountRow').style.display = 'flex';
                document.getElementById('discountAmount').textContent = '-' + formatPrice(currentDiscount) + ' đ';
            } else {
                document.getElementById('discountRow').style.display = 'none';
            }
            
            document.getElementById('checkoutTotal').textContent = formatPrice(finalAmount) + ' đ';
        }

        async function applyVoucher() {
            const voucherCode = document.getElementById('voucherCode').value.trim();
            const messageDiv = document.getElementById('voucherMessage');
            
            if (!voucherCode) {
                messageDiv.innerHTML = '<small class="text-danger">Vui lòng nhập mã voucher</small>';
                return;
            }

            try {
                const response = await fetch('@Url.Action("ValidateVoucher", "Checkout")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        voucherCode: voucherCode,
                        totalAmount: currentSubtotal
                    })
                });

                const result = await response.json();

                if (result.success) {
                    currentDiscount = result.discountAmount;
                    appliedVoucherCode = voucherCode;
                    messageDiv.innerHTML = `<small class="text-success">✓ Áp dụng voucher thành công! Giảm ${formatPrice(result.discountAmount)} đ</small>`;
                    updateTotals();
                } else {
                    currentDiscount = 0;
                    appliedVoucherCode = null;
                    messageDiv.innerHTML = `<small class="text-danger">${result.message}</small>`;
                    updateTotals();
                }
            } catch (error) {
                messageDiv.innerHTML = '<small class="text-danger">Có lỗi xảy ra khi kiểm tra voucher</small>';
            }
        }

        async function placeOrder() {
            const cart = getCart();
            if (!cart || cart.length === 0) {
                alert('Giỏ hàng trống!');
                return;
            }

            const btn = document.getElementById('placeOrderBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...';

            const orderData = {
                customerName: document.getElementById('customerName').value,
                phone: document.getElementById('phone').value,
                email: document.getElementById('email').value,
                address: document.getElementById('address').value,
                note: document.getElementById('note').value,
                paymentMethod: document.querySelector('input[name="paymentMethod"]:checked').value,
                voucherCode: appliedVoucherCode,
                items: cart.map(item => ({
                    productId: item.productId,
                    productType: item.productType,
                    quantity: item.quantity
                }))
            };

            try {
                const response = await fetch('@Url.Action("PlaceOrder", "Checkout")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(orderData)
                });

                const result = await response.json();

                if (result.success) {
                    // If VietQR, show QR code
                    if (result.paymentMethod === 'VietQR' && result.qrCode) {
                        qrCodeDataUrl = result.qrCode;
                        transferContentValue = result.transferContent;
                        
                        // Display QR code với style đẹp hơn
                        document.getElementById('qrCodeContainer').innerHTML = 
                            `<img src="${result.qrCode}" alt="QR Code" class="img-fluid" style="max-width: 280px; height: auto; border: 3px solid #fff; box-shadow: 0 4px 8px rgba(0,0,0,0.1);">`;
                        document.getElementById('transferContent').textContent = result.transferContent;
                        document.getElementById('qrTotalAmount').textContent = formatPrice(result.totalAmount) + ' đ';
                        
                        // Hiển thị section VietQR
                        document.getElementById('vietQRSection').style.display = 'block';
                        document.getElementById('paymentVietQR').checked = true;
                        
                        // Scroll to QR section
                        document.getElementById('vietQRSection').scrollIntoView({ behavior: 'smooth', block: 'center' });
                        
                        // Clear cart but don't redirect yet
                        clearCart();
                        updateCartIcon();
                        
                        // Disable form inputs nhưng giữ lại nút copy và download
                        document.getElementById('checkoutForm').querySelectorAll('input[type="text"], input[type="email"], input[type="tel"], textarea, button[type="submit"]').forEach(el => {
                            el.disabled = true;
                        });
                        
                        // Show success message
                        alert('✅ Đặt hàng thành công!\n\nMã đơn hàng: #' + result.orderId + '\nTổng tiền: ' + formatPrice(result.totalAmount) + ' đ\n\nVui lòng quét QR code để thanh toán.');
                    } else {
                        // Clear cart and redirect
                        clearCart();
                        updateCartIcon();
                        alert('Đặt hàng thành công! Mã đơn hàng: #' + result.orderId);
                        window.location.href = '@Url.Action("Index", "Home")';
                    }
                } else {
                    alert('Lỗi: ' + result.message);
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-check-circle"></i> Đặt hàng';
                }
            } catch (error) {
                alert('Có lỗi xảy ra: ' + error.message);
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check-circle"></i> Đặt hàng';
            }
        }
    </script>
}

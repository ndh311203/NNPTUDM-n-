@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h3 class="mb-0"> đăng nhập</h3>
                </div>
                <div class="card-body">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger" role="alert">
                            <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Index" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-3">
                            <label for="email" class="form-label">Email</label>
                            <input type="email" class="form-control" id="email" name="email" 
                                   placeholder="Nhập email" required autofocus>
                        </div>

                        <div class="mb-3">
                            <label for="matKhau" class="form-label">Mật khẩu</label>
                            <input type="password" class="form-control" id="matKhau" name="matKhau" 
                                   placeholder="Nhập mật khẩu" required>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                            </button>
                        </div>
                    </form>

                    <hr>

                    <!-- OAuth Login Buttons -->
                    <div class="mb-3">
                        <div class="text-center mb-2">
                            <small class="text-muted">Hoặc đăng nhập bằng</small>
                        </div>
                        <div class="d-grid gap-2">
                            <a href="@Url.Action("GoogleLogin", "Login")" class="btn btn-outline-danger">
                                <i class="bi bi-google"></i> Đăng nhập với Google
                            </a>
                            <a href="@Url.Action("FacebookLogin", "Login")" class="btn btn-outline-primary">
                                <i class="bi bi-facebook"></i> Đăng nhập với Facebook
                            </a>
                        </div>
                    </div>

                    <hr>

                    <div class="text-center">
                        <p class="mb-0">Chưa có tài khoản? <a href="/Register">Đăng ký ngay</a></p>
                    </div>
                </div>
                <div class="card-footer text-muted text-center">
                    <small>Hệ thống quản lý Spa Thú Cưng</small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border: none;
        border-radius: 10px;
    }
    .card-header {
        border-radius: 10px 10px 0 0 !important;
    }
</style>


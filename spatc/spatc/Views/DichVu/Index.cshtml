@model IEnumerable<spatc.Models.DichVu>
@{
    ViewData["Title"] = "Dịch vụ Spa Thú Cưng";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Dịch vụ Spa Thú Cưng</h1>
        <p class="lead text-muted">Chọn dịch vụ phù hợp cho thú cưng của bạn</p>
    </div>

    <!-- 2 Cards để chọn loại dịch vụ -->
    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="card h-100 shadow-lg border-primary" style="cursor: pointer;" onclick="window.location.href='@Url.Action("Grooming")'">
                <div class="card-body text-center p-5">
                    <div class="mb-4">
                        <i class="bi bi-scissors" style="font-size: 5rem; color: #ADD8E6;"></i>
                    </div>
                    <h2 class="card-title fw-bold mb-3">✂️ Dịch vụ Grooming</h2>
                    <p class="card-text text-muted mb-4">
                        Spa - Làm đẹp cho thú cưng<br>
                        Tắm spa, cắt tỉa lông, vệ sinh, massage, nhuộm lông
                    </p>
                    <a href="@Url.Action("Grooming")" class="btn btn-primary btn-lg">
                        <i class="bi bi-arrow-right-circle"></i> Xem dịch vụ Grooming
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100 shadow-lg border-warning" style="cursor: pointer;" onclick="window.location.href='@Url.Action("KhachSan")'">
                <div class="card-body text-center p-5">
                    <div class="mb-4">
                        <i class="bi bi-building" style="font-size: 5rem; color: #ffc107;"></i>
                    </div>
                    <h2 class="card-title fw-bold mb-3">🏨 Khách Sạn Thú Cưng</h2>
                    <p class="card-text text-muted mb-4">
                        Dịch vụ lưu trú cho thú cưng<br>
                        Phòng thường, VIP, siêu VIP với đầy đủ tiện nghi
                    </p>
                    <a href="@Url.Action("KhachSan")" class="btn btn-warning btn-lg">
                        <i class="bi bi-arrow-right-circle"></i> Xem phòng khách sạn
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Call to Action -->
    <div class="text-center mt-5 mb-4">
            <div class="card" style="background: linear-gradient(135deg, #ADD8E6 0%, #87CEEB 100%);">
                <div class="card-body py-5">
                    <h3 class="card-title" style="color: #654321;">Sẵn sàng đặt lịch cho thú cưng của bạn?</h3>
                    <p class="card-text" style="color: #8B4513;">Chúng tôi sẽ chăm sóc thú cưng của bạn một cách tốt nhất</p>
                    <a href="@Url.Action("Index", "DatLich")" class="btn btn-lg" style="background: #FFE5E5; color: #654321; border: none;">
                        <i class="bi bi-calendar-check"></i> Đặt lịch ngay
                    </a>
                </div>
            </div>
    </div>
</div>

<style>
    .card:hover {
        transform: translateY(-5px);
        transition: transform 0.3s ease;
    }
</style>

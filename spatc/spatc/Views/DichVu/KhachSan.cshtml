@model List<spatc.Models.DichVu>
@{
    ViewData["Title"] = "Khách Sạn Thú Cưng";
}

<div class="container mt-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Index")">Dịch vụ</a></li>
            <li class="breadcrumb-item active">Khách Sạn</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold">
                <span class="text-warning">🏨</span> Khách Sạn Thú Cưng (Lưu trú)
            </h1>
            <p class="text-muted">Dịch vụ lưu trú an toàn và tiện nghi cho thú cưng của bạn</p>
        </div>
        <a href="@Url.Action("Grooming")" class="btn btn-outline-primary">
            <i class="bi bi-scissors"></i> Xem Grooming
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var service in Model)
            {
                <div class="col-md-4 col-lg-3">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(service.HinhAnh))
                        {
                            <img src="@service.HinhAnh" class="card-img-top" alt="@service.TenDichVu" style="height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                <i class="bi bi-image fs-1 text-muted"></i>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title">@service.TenDichVu</h5>
                            <p class="card-text text-muted small">
                                @if (!string.IsNullOrEmpty(service.MoTa))
                                {
                                    var moTa = service.MoTa != null && service.MoTa.Length > 100 ? service.MoTa.Substring(0, 100) + "..." : service.MoTa;
                                    @moTa
                                }
                            </p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="h5 text-primary mb-0">@service.Gia.ToString("N0") đ</span>
                                <a href="@Url.Action("Details", "DichVu", new { id = service.Id })" class="btn btn-primary btn-sm" style="color: #654321 !important;">
                                    <i class="bi bi-eye"></i> Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-info-circle fs-1"></i>
            <h4 class="mt-3">Chưa có dịch vụ Khách Sạn nào</h4>
            <p class="text-muted">Vui lòng quay lại sau</p>
        </div>
    }

    <!-- Back button -->
    <div class="text-center mt-5">
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại trang dịch vụ
        </a>
    </div>
</div>


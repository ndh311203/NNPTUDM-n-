@model spatc.Models.DichVu
@{
    ViewData["Title"] = Model.TenDichVu;
    var dichVuKhac = ViewBag.DichVuKhac as List<spatc.Models.DichVu> ?? new List<spatc.Models.DichVu>();
    var averageRating = Model.AverageRating ?? 0;
    var reviewCount = Model.ReviewCount;
}

<style>
    .rating-stars {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .star-filled {
        color: #ffc107;
        font-size: 18px;
    }

    .star-empty {
        color: #ddd;
        font-size: 18px;
    }

    .rating-input {
        display: flex;
        flex-direction: row-reverse;
        justify-content: flex-end;
        gap: 5px;
    }

    .rating-input input[type="radio"] {
        display: none;
    }

    .rating-input .star-label {
        font-size: 30px;
        color: #ddd;
        cursor: pointer;
        transition: color 0.2s;
    }

    .rating-input input[type="radio"]:checked ~ .star-label,
    .rating-input .star-label:hover,
    .rating-input .star-label:hover ~ .star-label {
        color: #ffc107;
    }

    .review-item {
        border-bottom: 1px solid #e0e0e0;
        padding: 15px 0;
    }

    .review-item:last-child {
        border-bottom: none;
    }

    .review-images {
        display: flex;
        gap: 10px;
        margin-top: 10px;
        flex-wrap: wrap;
    }

    .review-image {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border-radius: 4px;
        cursor: pointer;
        border: 1px solid #ddd;
    }

    .review-image:hover {
        border-color: #007bff;
        transform: scale(1.05);
        transition: all 0.2s;
    }
</style>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <h1 class="mb-3">@Model.TenDichVu</h1>
            
            @* Hiển thị đánh giá trung bình *@
            @if (reviewCount > 0)
            {
                <div class="mb-3">
                    <div class="rating-stars" id="ratingDisplay">
                        @for (int i = 0; i < 5; i++)
                        {
                            if (i < Math.Floor((double)averageRating))
                            {
                                <span class="star-filled">★</span>
                            }
                            else if (i == Math.Floor((double)averageRating) && averageRating % 1 >= 0.5m)
                            {
                                <span class="star-filled">☆</span>
                            }
                            else
                            {
                                <span class="star-empty">★</span>
                            }
                        }
                        <span style="margin-left: 8px; font-size: 16px;">@averageRating.ToString("F1")</span>
                        <span style="margin-left: 8px; color: #666;">(@reviewCount đánh giá)</span>
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.HinhAnh))
            {
                <img src="@Model.HinhAnh" class="img-fluid rounded mb-4" alt="@Model.TenDichVu">
            }
            
            @* Tabs cho mô tả và đánh giá *@
            <ul class="nav nav-tabs mb-3" id="serviceTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="description-tab" data-bs-toggle="tab" data-bs-target="#description" type="button" role="tab">
                        Mô tả dịch vụ
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews" type="button" role="tab">
                        Đánh giá (@reviewCount)
                    </button>
                </li>
            </ul>

            <div class="tab-content" id="serviceTabContent">
                <div class="tab-pane fade show active" id="description" role="tabpanel">
                    <h5>Mô tả dịch vụ</h5>
                    <p class="lead">@Html.Raw(Model.MoTa?.Replace("\n", "<br>") ?? "Chưa có mô tả")</p>
                </div>
                <div class="tab-pane fade" id="reviews" role="tabpanel">
                    <h5>Đánh giá dịch vụ</h5>
                    <div id="reviewsContainer">
                        <!-- Reviews will be loaded by JavaScript -->
                    </div>
                </div>
            </div>
            
            @* Form đánh giá luôn hiển thị *@
            <div class="card mt-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">⭐ Viết đánh giá</h5>
                </div>
                <div class="card-body">
                    <form id="reviewFormElement">
                        <div class="mb-3">
                            <label class="form-label">Đánh giá *</label>
                            <div class="rating-input">
                                <input type="radio" name="rating" id="star5" value="5" checked>
                                <label for="star5" class="star-label">★</label>
                                <input type="radio" name="rating" id="star4" value="4">
                                <label for="star4" class="star-label">★</label>
                                <input type="radio" name="rating" id="star3" value="3">
                                <label for="star3" class="star-label">★</label>
                                <input type="radio" name="rating" id="star2" value="2">
                                <label for="star2" class="star-label">★</label>
                                <input type="radio" name="rating" id="star1" value="1">
                                <label for="star1" class="star-label">★</label>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Tên của bạn *</label>
                            <input type="text" class="form-control" id="reviewCustomerName" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" id="reviewCustomerEmail">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Bình luận</label>
                            <textarea class="form-control" id="reviewComment" rows="4"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Hình ảnh (tối đa 3 ảnh)</label>
                            <input type="text" class="form-control" id="reviewImages" placeholder="URL ảnh, cách nhau bằng dấu phẩy">
                            <small class="text-muted">Nhập URL hình ảnh, cách nhau bằng dấu phẩy</small>
                        </div>
                        <button type="submit" class="btn btn-primary">Gửi đánh giá</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-body">
                    <h4 class="card-title text-primary mb-3">@Model.Gia.ToString("N0") đ</h4>
                    <a href="@Url.Action("Index", "DatLich", new { dichVuId = Model.Id })" class="btn btn-primary btn-lg w-100 mb-3">
                        <i class="bi bi-calendar-check"></i> Đặt lịch ngay
                    </a>
                    <hr>
                    <h5>Gợi ý combo</h5>
                    @if (dichVuKhac.Any())
                    {
                        <ul class="list-unstyled">
                            @foreach (var dv in dichVuKhac)
                            {
                                <li class="mb-2">
                                    <a href="@Url.Action("Details", "DichVu", new { id = dv.Id })" class="text-decoration-none">
                                        @dv.TenDichVu - @dv.Gia.ToString("N0") đ
                                    </a>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const dichVuId = @Model.Id;
        const averageRatingValue = @averageRating;

        document.addEventListener('DOMContentLoaded', function() {
            // Load reviews when reviews tab is clicked
            document.getElementById('reviews-tab')?.addEventListener('shown.bs.tab', function() {
                loadReviews();
            });

            // Load reviews if reviews tab is active on page load
            if (document.getElementById('reviews-tab')?.classList.contains('active')) {
                loadReviews();
            }

            // Handle review form submission
            document.getElementById('reviewFormElement')?.addEventListener('submit', async function(e) {
                e.preventDefault();
                await submitReview();
            });
        });

        async function loadReviews() {
            try {
                const response = await fetch(`@Url.Action("GetReviews", "ServiceReview")?dichVuId=${dichVuId}`);
                const result = await response.json();
                
                if (result.success && result.reviews.length > 0) {
                    let html = '';
                    result.reviews.forEach(review => {
                        const stars = generateReviewStars(review.rating);
                        const imagesHtml = review.images && review.images.length > 0
                            ? `<div class="review-images">${review.images.map(img => `<img src="${img}" class="review-image" onclick="showImageModal('${img}')">`).join('')}</div>`
                            : '';
                        
                        html += `
                            <div class="review-item">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <strong>${review.customerName}</strong>
                                        <div class="rating-stars">${stars}</div>
                                    </div>
                                    <small class="text-muted">${review.createdAt}</small>
                                </div>
                                ${review.comment ? `<p>${review.comment}</p>` : ''}
                                ${imagesHtml}
                            </div>
                        `;
                    });
                    document.getElementById('reviewsContainer').innerHTML = html;
                } else {
                    document.getElementById('reviewsContainer').innerHTML = '<p class="text-muted">Chưa có đánh giá nào</p>';
                }
            } catch (error) {
                console.error('Error loading reviews:', error);
                document.getElementById('reviewsContainer').innerHTML = '<p class="text-danger">Có lỗi xảy ra khi tải đánh giá</p>';
            }
        }

        function generateReviewStars(rating) {
            let html = '';
            for (let i = 0; i < 5; i++) {
                html += i < rating ? '<span class="star-filled">★</span>' : '<span class="star-empty">★</span>';
            }
            return html;
        }

        async function submitReview() {
            // Kiểm tra rating đã chọn
            const ratingInput = document.querySelector('input[name="rating"]:checked');
            if (!ratingInput) {
                alert('Vui lòng chọn đánh giá (sao)');
                return;
            }

            const rating = parseInt(ratingInput.value);
            const customerName = document.getElementById('reviewCustomerName')?.value?.trim();
            const customerEmail = document.getElementById('reviewCustomerEmail')?.value?.trim();
            const comment = document.getElementById('reviewComment')?.value?.trim();
            const images = document.getElementById('reviewImages')?.value?.trim();

            if (!customerName) {
                alert('Vui lòng nhập tên của bạn');
                return;
            }

            if (rating < 1 || rating > 5) {
                alert('Đánh giá phải từ 1 đến 5 sao');
                return;
            }

            try {
                const reviewData = {
                    dichVuId: dichVuId,
                    rating: rating,
                    comment: comment || null,
                    images: images || null,
                    customerName: customerName,
                    customerEmail: customerEmail || null
                };

                console.log('Submitting review:', reviewData);

                const response = await fetch('/ServiceReview/Create', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(reviewData)
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    console.error('Response error:', errorText);
                    throw new Error(`HTTP ${response.status}: ${errorText}`);
                }

                const result = await response.json();
                console.log('Review result:', result);

                if (result.success) {
                    alert('Đánh giá của bạn đã được gửi thành công!');
                    // Reset form
                    document.getElementById('reviewFormElement').reset();
                    // Reload reviews
                    await loadReviews();
                    // Reload page to update rating display
                    location.reload();
                } else {
                    alert('Lỗi: ' + (result.message || 'Không thể gửi đánh giá'));
                }
            } catch (error) {
                console.error('Error submitting review:', error);
                alert('Có lỗi xảy ra khi gửi đánh giá. Vui lòng thử lại sau.');
            }
        }

        function showImageModal(imageUrl) {
            // Simple modal to show image
            const modal = document.createElement('div');
            modal.style.cssText = 'position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 9999; display: flex; align-items: center; justify-content: center; cursor: pointer;';
            modal.onclick = function() { document.body.removeChild(modal); };
            
            const img = document.createElement('img');
            img.src = imageUrl;
            img.style.cssText = 'max-width: 90%; max-height: 90%; object-fit: contain;';
            modal.appendChild(img);
            
            document.body.appendChild(modal);
        }
    </script>
}


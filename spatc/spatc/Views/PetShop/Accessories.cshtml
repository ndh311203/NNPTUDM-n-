@model IEnumerable<spatc.Models.AccessoryProduct>
@{
    ViewData["Title"] = "Phụ Kiện Thú Cưng";
}

<div class="container mt-4">
    <h2 class="mb-4">🎁 Phụ Kiện Thú Cưng</h2>

    <!-- Thanh tìm kiếm với gợi ý -->
    @await Html.PartialAsync("_SearchBar")

    <!-- Bộ lọc -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" action="@Url.Action("Accessories")" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Phân loại</label>
                    <select name="category" class="form-select">
                        <option value="">Tất cả</option>
                        @foreach (var c in ViewBag.Categories as List<string>)
                        {
                            <option value="@c" selected="@(ViewBag.SelectedCategory == c)">@c</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Giá từ (VNĐ)</label>
                    <input type="number" name="minPrice" class="form-control" value="@ViewBag.MinPrice" placeholder="0">
                </div>
                <div class="col-md-2">
                    <label class="form-label">Giá đến (VNĐ)</label>
                    <input type="number" name="maxPrice" class="form-control" value="@ViewBag.MaxPrice" placeholder="999999999">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Sắp xếp</label>
                    <select name="sortBy" class="form-select">
                        <option value="">Mới nhất</option>
                        <option value="price_asc" selected="@(ViewBag.SortBy == "price_asc")">Giá tăng dần</option>
                        <option value="price_desc" selected="@(ViewBag.SortBy == "price_desc")">Giá giảm dần</option>
                        <option value="name_asc" selected="@(ViewBag.SortBy == "name_asc")">Tên A-Z</option>
                        <option value="name_desc" selected="@(ViewBag.SortBy == "name_desc")">Tên Z-A</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Lọc</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Danh sách sản phẩm -->
    <div class="row g-4">
        @foreach (var accessory in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(accessory.Image))
                    {
                        <img src="@accessory.Image" class="card-img-top" alt="@accessory.Name" style="height: 250px; object-fit: cover;">
                    }
                    else
                    {
                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 250px;">
                            <span class="text-muted">Chưa có hình ảnh</span>
                        </div>
                    }
                    <div class="card-body">
                        <span class="badge bg-info mb-2">@accessory.Category</span>
                        <h5 class="card-title">@accessory.Name</h5>
                        @if (!string.IsNullOrEmpty(accessory.Material))
                        {
                            <p class="card-text text-muted small">Chất liệu: @accessory.Material</p>
                        }
                        <p class="card-text text-success small">Còn hàng: @accessory.SoLuongTon sản phẩm</p>
                        <h4 class="text-primary fw-bold">@accessory.Price.ToString("N0") đ</h4>
                    </div>
                    <div class="card-footer bg-white">
                        <a href="@Url.Action("AccessoryDetails", new { id = accessory.Id })" class="btn btn-primary w-100">Xem chi tiết</a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            <p class="mb-0">Không tìm thấy phụ kiện nào phù hợp với bộ lọc của bạn.</p>
        </div>
    }
</div>


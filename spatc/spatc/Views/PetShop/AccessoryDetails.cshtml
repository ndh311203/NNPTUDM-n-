@model spatc.Models.AccessoryProduct
@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            @if (!string.IsNullOrEmpty(Model.Image))
            {
                <img src="@Model.Image" class="img-fluid rounded" alt="@Model.Name" style="max-height: 500px; object-fit: cover;">
            }
            else
            {
                <div class="bg-light d-flex align-items-center justify-content-center rounded" style="height: 500px;">
                    <span class="text-muted">Chưa có hình ảnh</span>
                </div>
            }
        </div>
        <div class="col-md-6">
            <h1>@Model.Name</h1>
            <span class="badge bg-info fs-6 mb-3">@Model.Category</span>
            
            <div class="mb-4">
                <h2 class="text-primary fw-bold">@Model.Price.ToString("N0") đ</h2>
            </div>

            <dl class="row mb-4">
                @if (!string.IsNullOrEmpty(Model.Material))
                {
                    <dt class="col-sm-4">Chất liệu:</dt>
                    <dd class="col-sm-8">@Model.Material</dd>
                }
                <dt class="col-sm-4">Số lượng tồn:</dt>
                <dd class="col-sm-8">
                    @if (Model.SoLuongTon > 0)
                    {
                        <span class="text-success">Còn @Model.SoLuongTon sản phẩm</span>
                    }
                    else
                    {
                        <span class="text-danger">Hết hàng</span>
                    }
                </dd>
            </dl>

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="mb-4">
                    <h5>Mô tả:</h5>
                    <p>@Html.Raw(Model.Description.Replace("\n", "<br>"))</p>
                </div>
            }

            <div class="mb-3">
                <label class="form-label">Số lượng:</label>
                <div class="input-group" style="width: 150px;">
                    <button class="btn btn-outline-secondary" type="button" onclick="decreaseAccessoryQuantity()">-</button>
                    <input type="number" class="form-control text-center" id="accessoryQuantity" value="1" min="1" max="@Model.SoLuongTon">
                    <button class="btn btn-outline-secondary" type="button" onclick="increaseAccessoryQuantity()">+</button>
                </div>
                <small class="text-muted">Tối đa: @Model.SoLuongTon sản phẩm</small>
            </div>

            <div class="d-grid gap-2">
                @if (Model.SoLuongTon > 0)
                {
                    <button class="btn btn-primary btn-lg" id="addToCartBtn" onclick="addAccessoryToCart(@Model.Id)">
                        <i class="bi bi-cart-plus"></i> Thêm vào giỏ hàng
                    </button>
                }
                else
                {
                    <button class="btn btn-secondary btn-lg" disabled>Hết hàng</button>
                }
                <a href="@Url.Action("Accessories")" class="btn btn-outline-secondary">← Quay lại danh sách</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const maxStock = @Model.SoLuongTon;

        function increaseAccessoryQuantity() {
            const input = document.getElementById('accessoryQuantity');
            const current = parseInt(input.value);
            if (current < maxStock) {
                input.value = current + 1;
            }
        }

        function decreaseAccessoryQuantity() {
            const input = document.getElementById('accessoryQuantity');
            const current = parseInt(input.value);
            if (current > 1) {
                input.value = current - 1;
            }
        }

        async function addAccessoryToCart(accessoryId) {
            const quantity = parseInt(document.getElementById('accessoryQuantity').value);
            const btn = document.getElementById('addToCartBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang thêm...';

            const result = await addToCart(accessoryId, 'accessory', quantity);
            
            if (result.success) {
                alert('Đã thêm vào giỏ hàng!');
            } else {
                alert(result.message);
            }

            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-cart-plus"></i> Thêm vào giỏ hàng';
        }
    </script>
}
        </div>
    </div>
</div>


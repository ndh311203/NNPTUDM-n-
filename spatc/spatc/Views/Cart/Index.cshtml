@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="container mt-4">
    <h2 class="mb-4">🛒 Giỏ hàng của bạn</h2>

    <div id="cartEmpty" class="alert alert-info text-center" style="display: none;">
        <h4>Giỏ hàng trống</h4>
        <p>Bạn chưa có sản phẩm nào trong giỏ hàng.</p>
        <a href="@Url.Action("Index", "PetShop")" class="btn btn-primary">Tiếp tục mua sắm</a>
    </div>

    <div id="cartContent" style="display: none;">
        <div class="row">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-body">
                        <div id="cartItems">
                            <!-- Cart items will be loaded here by JavaScript -->
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Tóm tắt đơn hàng</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Tạm tính:</span>
                            <span id="subtotal">0 đ</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-3">
                            <strong>Tổng tiền:</strong>
                            <strong class="text-primary fs-5" id="total">0 đ</strong>
                        </div>
                        <div class="d-grid gap-2">
                            <a href="@Url.Action("Index", "Checkout")" class="btn btn-primary btn-lg" id="checkoutBtn">
                                <i class="bi bi-credit-card"></i> Thanh toán
                            </a>
                            <a href="@Url.Action("Index", "PetShop")" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Tiếp tục mua sắm
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/cart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            loadCart();
        });
    </script>
}


@{
    ViewData["Title"] = "Trang quản trị";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Trang quản trị</h2>
        <div>
            <span class="text-muted">Xin chào, <strong>@ViewBag.UserName</strong></span>
            <a href="@Url.Action("Logout", "Login")" class="btn btn-outline-danger btn-sm ms-2">
                <i class="bi bi-box-arrow-right"></i> Đăng xuất
            </a>
        </div>
    </div>

    <!-- Thống kê -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5 class="card-title">Tổng đặt lịch</h5>
                    <h2 class="mb-0">@ViewBag.TongDatLich</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h5 class="card-title">Chờ xác nhận</h5>
                    <h2 class="mb-0">@ViewBag.DatLichCho</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h5 class="card-title">Đang làm</h5>
                    <h2 class="mb-0">@ViewBag.DatLichDangLam</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">Hoàn thành</h5>
                    <h2 class="mb-0">@ViewBag.DatLichHoanThanh</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Tổng khách hàng</h5>
                    <h2 class="mb-0 text-primary">@ViewBag.TongKhachHang</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Tổng thú cưng</h5>
                    <h2 class="mb-0 text-primary">@ViewBag.TongThuCung</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Tổng dịch vụ</h5>
                    <h2 class="mb-0 text-primary">@ViewBag.TongDichVu</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">Tổng doanh thu</h5>
                    <h2 class="mb-0">@(((decimal)ViewBag.TongDoanhThu).ToString("N0")) đ</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Menu quản lý -->
    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="card text-center h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Quản lý đặt lịch</h5>
                    <p class="card-text text-muted">Quản lý các đơn đặt lịch spa</p>
                    <a href="/Admin/DatLich" class="btn btn-primary">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card text-center h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Quản lý khách hàng</h5>
                    <p class="card-text text-muted">Quản lý thông tin khách hàng</p>
                    <a href="/Admin/KhachHang" class="btn btn-primary">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card text-center h-100 shadow-sm border-secondary">
                <div class="card-body">
                    <h5 class="card-title">👥 Quản lý thú cưng khách hàng</h5>
                    <p class="card-text text-muted">Thú cưng của khách hàng (để đặt lịch dịch vụ)</p>
                    <a href="/Admin/ThuCung" class="btn btn-primary" style="color: #654321 !important;">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card text-center h-100 shadow-sm border-primary">
                <div class="card-body">
                    <h5 class="card-title">✂️ Dịch vụ Grooming</h5>
                    <p class="card-text text-muted">Quản lý dịch vụ spa - làm đẹp</p>
                    <a href="/Admin/Grooming" class="btn btn-primary">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card text-center h-100 shadow-sm border-warning">
                <div class="card-body">
                    <h5 class="card-title">🏨 Khách Sạn Thú Cưng</h5>
                    <p class="card-text text-muted">Quản lý phòng lưu trú</p>
                    <a href="/Admin/KhachSan" class="btn btn-primary" style="color: #654321 !important;">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card text-center h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Quản lý nhân viên</h5>
                    <p class="card-text text-muted">Quản lý thông tin nhân viên</p>
                    <a href="/Admin/NhanVien" class="btn btn-primary">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card text-center h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Quản lý hóa đơn</h5>
                    <p class="card-text text-muted">Quản lý hóa đơn thanh toán</p>
                    <a href="/Admin/HoaDon" class="btn btn-primary">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card text-center h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Quản lý tài khoản</h5>
                    <p class="card-text text-muted">Quản lý tài khoản admin và nhân viên</p>
                    <a href="/Admin/TaiKhoan" class="btn btn-primary">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card text-center h-100 shadow-sm border-primary">
                <div class="card-body">
                    <h5 class="card-title">🛒 Quản lý thú cưng bán</h5>
                    <p class="card-text text-muted">Quản lý thú cưng đang bán</p>
                    <a href="/Admin/PetProduct" class="btn btn-primary">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card text-center h-100 shadow-sm border-success">
                <div class="card-body">
                    <h5 class="card-title">🍖 Quản lý thức ăn</h5>
                    <p class="card-text text-muted">Quản lý thức ăn cho thú cưng</p>
                    <a href="/Admin/FoodProduct" class="btn btn-primary" style="color: #654321 !important;">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card text-center h-100 shadow-sm border-info">
                <div class="card-body">
                    <h5 class="card-title">🎁 Quản lý phụ kiện</h5>
                    <p class="card-text text-muted">Quản lý phụ kiện thú cưng</p>
                    <a href="/Admin/AccessoryProduct" class="btn btn-primary" style="color: #654321 !important;">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card text-center h-100 shadow-sm border-warning">
                <div class="card-body">
                    <h5 class="card-title">📦 Quản lý đơn hàng Pet Shop</h5>
                    <p class="card-text text-muted">Quản lý đơn hàng từ cửa hàng</p>
                    <a href="/Admin/ShopOrder" class="btn btn-primary" style="color: #654321 !important;">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card text-center h-100 shadow-sm border-danger">
                <div class="card-body">
                    <h5 class="card-title">🎫 Quản lý Voucher</h5>
                    <p class="card-text text-muted">Quản lý mã giảm giá</p>
                    <a href="/Admin/Voucher" class="btn btn-primary" style="color: #654321 !important;">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card text-center h-100 shadow-sm border-info">
                <div class="card-body">
                    <h5 class="card-title">📊 Dashboard Doanh Thu</h5>
                    <p class="card-text text-muted">Thống kê doanh số Pet Shop</p>
                    <a href="/Admin/Dashboard" class="btn btn-primary" style="color: #654321 !important;">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card text-center h-100 shadow-sm border-secondary">
                <div class="card-body">
                    <h5 class="card-title">⭐ Quản lý Đánh giá</h5>
                    <p class="card-text text-muted">Quản lý đánh giá sản phẩm</p>
                    <a href="/Admin/ProductReview" class="btn btn-primary" style="color: #654321 !important;">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card text-center h-100 shadow-sm border-primary">
                <div class="card-body">
                    <h5 class="card-title">💬 Quản lý Chat</h5>
                    <p class="card-text text-muted">Hỗ trợ khách hàng qua chat</p>
                    <a href="/Admin/AdminChat" class="btn btn-primary" style="color: #654321 !important;">Xem chi tiết</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Đặt lịch mới nhất -->
    @if (ViewBag.DatLichMoi != null)
    {
        <div class="card">
            <div class="card-header">
                <h5>Đặt lịch mới nhất</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Thời gian hẹn</th>
                                <th>Khách hàng</th>
                                <th>Thú cưng</th>
                                <th>Dịch vụ</th>
                                <th>Trạng thái</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var dl in ViewBag.DatLichMoi as List<spatc.Models.DatLich>)
                            {
                                <tr>
                                    <td>@dl.ThoiGianHen.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@dl.ThuCung?.KhachHang?.HoTen</td>
                                    <td>@dl.ThuCung?.TenThuCung</td>
                                    <td>@dl.DichVu?.TenDichVu</td>
                                    <td>
                                        <span class="badge bg-@(dl.TrangThai == "Chờ" ? "warning" : dl.TrangThai == "Đang làm" ? "info" : dl.TrangThai == "Hoàn thành" ? "success" : "danger")">
                                            @dl.TrangThai
                                        </span>
                                    </td>
                                    <td>
                                        <a href="/Admin/DatLich/Details/@dl.Id" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>


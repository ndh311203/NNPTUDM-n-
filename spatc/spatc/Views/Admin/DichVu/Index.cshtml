@model spatc.Models.DichVuIndexViewModel
@{
    ViewData["Title"] = "Quản lý Dịch vụ";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>Quản lý Dịch vụ</h2>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Thêm dịch vụ mới
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Phần 1: Dịch vụ Grooming -->
    <div class="card mb-4" style="border-left: 4px solid #0d6efd;">
        <div class="card-header bg-light">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0">
                    <span class="text-primary">✂️</span> Dịch vụ Grooming
                </h4>
                <span class="badge bg-info">@Model.Grooming.Count() dịch vụ</span>
            </div>
        </div>
        <div class="card-body">
            @if (Model.Grooming.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Tên dịch vụ</th>
                                <th>Giá</th>
                                <th>Hình ảnh</th>
                                <th>Trạng thái</th>
                                <th>Ngày tạo</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Grooming)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td>@item.TenDichVu</td>
                                    <td class="fw-bold text-primary">@item.Gia.ToString("N0") đ</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.HinhAnh))
                                        {
                                            <img src="@item.HinhAnh" alt="@item.TenDichVu" style="width: 50px; height: 50px; object-fit: cover;" class="rounded">
                                        }
                                        else
                                        {
                                            <span class="text-muted">Chưa có</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.TrangThai)
                                        {
                                            <span class="badge bg-success">Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Ngừng</span>
                                        }
                                    </td>
                                    <td>@item.NgayTao.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-sm btn-info">
                                            <i class="bi bi-search"></i> Chi tiết
                                        </a>
                                        <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-warning">
                                            <i class="bi bi-pencil"></i> Sửa
                                        </a>
                                        <a href="@Url.Action("Delete", new { id = item.Id })" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i> Xóa
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center py-3 mb-0">
                    <i class="bi bi-info-circle"></i> Chưa có dịch vụ Grooming nào
                </div>
            }
        </div>
    </div>

    <!-- Phần 2: Dịch vụ Khách Sạn -->
    <div class="card" style="border-left: 4px solid #ffc107;">
        <div class="card-header bg-light">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0">
                    <span class="text-warning">🏨</span> Dịch vụ Khách Sạn Thú Cưng
                </h4>
                <span class="badge bg-warning text-dark">@Model.KhachSan.Count() dịch vụ</span>
            </div>
        </div>
        <div class="card-body">
            @if (Model.KhachSan.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Tên dịch vụ</th>
                                <th>Giá</th>
                                <th>Hình ảnh</th>
                                <th>Trạng thái</th>
                                <th>Ngày tạo</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.KhachSan)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td>@item.TenDichVu</td>
                                    <td class="fw-bold text-primary">@item.Gia.ToString("N0") đ</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.HinhAnh))
                                        {
                                            <img src="@item.HinhAnh" alt="@item.TenDichVu" style="width: 50px; height: 50px; object-fit: cover;" class="rounded">
                                        }
                                        else
                                        {
                                            <span class="text-muted">Chưa có</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.TrangThai)
                                        {
                                            <span class="badge bg-success">Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Ngừng</span>
                                        }
                                    </td>
                                    <td>@item.NgayTao.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-sm btn-info">
                                            <i class="bi bi-search"></i> Chi tiết
                                        </a>
                                        <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-warning">
                                            <i class="bi bi-pencil"></i> Sửa
                                        </a>
                                        <a href="@Url.Action("Delete", new { id = item.Id })" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i> Xóa
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center py-3 mb-0">
                    <i class="bi bi-info-circle"></i> Chưa có dịch vụ Khách Sạn nào
                </div>
            }
        </div>
    </div>
</div>

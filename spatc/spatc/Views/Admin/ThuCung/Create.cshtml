@model spatc.Models.ThuCung
@{
    ViewData["Title"] = "Thêm thú cưng mới";
}

<div class="container mt-4">
    <h2>Thêm thú cưng mới</h2>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="mb-3">
                    <label asp-for="TenThuCung" class="form-label">Tên thú cưng *</label>
                    <input asp-for="TenThuCung" class="form-control" />
                    <span asp-validation-for="TenThuCung" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Loai" class="form-label">Loại *</label>
                            <select asp-for="Loai" class="form-select" required>
                                <option value="">-- Chọn loại --</option>
                                <option value="Chó">🐕 Chó</option>
                                <option value="Mèo">🐱 Mèo</option>
                                <option value="Hamster">🐹 Hamster</option>
                                <option value="Thỏ">🐰 Thỏ</option>
                                <option value="Chim">🐦 Chim</option>
                                <option value="Khác">Khác</option>
                            </select>
                            <span asp-validation-for="Loai" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Giong" class="form-label">Giống</label>
                            <input asp-for="Giong" class="form-control" placeholder="Ví dụ: Golden Retriever, Persian" />
                            <span asp-validation-for="Giong" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Tuoi" class="form-label">Tuổi (tháng)</label>
                            <input asp-for="Tuoi" class="form-control" type="number" min="0" />
                            <span asp-validation-for="Tuoi" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="CanNang" class="form-label">Cân nặng (kg)</label>
                            <input asp-for="CanNang" class="form-control" type="number" step="0.01" min="0" />
                            <span asp-validation-for="CanNang" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="GhiChuSucKhoe" class="form-label">Ghi chú sức khỏe</label>
                    <textarea asp-for="GhiChuSucKhoe" class="form-control" rows="3" placeholder="Ví dụ: Đã tiêm phòng đầy đủ, khỏe mạnh..."></textarea>
                    <span asp-validation-for="GhiChuSucKhoe" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="HinhAnh" class="form-label">URL Hình ảnh</label>
                    <input asp-for="HinhAnh" class="form-control" placeholder="https://..." />
                    <span asp-validation-for="HinhAnh" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Thêm mới</button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}


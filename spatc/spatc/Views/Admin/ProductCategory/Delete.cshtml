@model spatc.Models.ProductCategory
@{
    ViewData["Title"] = "Xóa danh mục";
    var productsUsingCategory = ViewBag.ProductsUsingCategory as int? ?? 0;
}

<div class="container mt-4">
    <h2>Xóa danh mục</h2>
    <hr />

    @if (productsUsingCategory > 0)
    {
        <div class="alert alert-danger">
            <strong>Cảnh báo!</strong> Có @productsUsingCategory sản phẩm đang sử dụng danh mục này. Không thể xóa!
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <strong>Bạn có chắc chắn muốn xóa danh mục này?</strong>
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-3">Tên danh mục:</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Mã danh mục:</dt>
                <dd class="col-sm-9"><code>@Model.Slug</code></dd>

                @if (productsUsingCategory > 0)
                {
                    <dt class="col-sm-3">Số sản phẩm:</dt>
                    <dd class="col-sm-9 text-danger">@productsUsingCategory sản phẩm đang sử dụng</dd>
                }
            </dl>

            @if (productsUsingCategory == 0)
            {
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="mb-3">
                        <button type="submit" class="btn btn-danger">Xóa</button>
                        <a href="@Url.Action("Index")" class="btn btn-secondary">Quay lại</a>
                    </div>
                </form>
            }
            else
            {
                <div class="mb-3">
                    <a href="@Url.Action("Index")" class="btn btn-secondary">Quay lại</a>
                </div>
            }
        </div>
    </div>
</div>


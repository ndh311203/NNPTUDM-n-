@model IEnumerable<spatc.Models.ProductReview>
@{
    ViewData["Title"] = "Quản lý Đánh giá Sản phẩm";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Quản lý Đánh giá Sản phẩm</h2>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filters -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Trạng thái</label>
                    <select name="status" class="form-select">
                        <option value="">Tất cả</option>
                        <option value="approved" selected="@(ViewBag.StatusFilter == "approved")">Đã duyệt</option>
                        <option value="pending" selected="@(ViewBag.StatusFilter == "pending")">Chờ duyệt</option>
                        <option value="rejected" selected="@(ViewBag.StatusFilter == "rejected")">Từ chối</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Loại sản phẩm</label>
                    <select name="productType" class="form-select">
                        <option value="">Tất cả</option>
                        <option value="pet" selected="@(ViewBag.ProductTypeFilter == "pet")">Thú cưng</option>
                        <option value="food" selected="@(ViewBag.ProductTypeFilter == "food")">Thức ăn</option>
                        <option value="accessory" selected="@(ViewBag.ProductTypeFilter == "accessory")">Phụ kiện</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Mã sản phẩm</label>
                    <input type="number" name="productId" class="form-control" value="@ViewBag.ProductIdFilter" placeholder="ID sản phẩm">
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Lọc</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Sản phẩm</th>
                            <th>Khách hàng</th>
                            <th>Đánh giá</th>
                            <th>Bình luận</th>
                            <th>Hình ảnh</th>
                            <th>Trạng thái</th>
                            <th>Ngày tạo</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var review in Model)
                        {
                            <tr>
                                <td>@review.Id</td>
                                <td>
                                    <div>
                                        <strong>ID: @review.ProductId</strong>
                                        <div class="small text-muted">@review.ProductType</div>
                                    </div>
                                </td>
                                <td>
                                    <div>@review.CustomerName</div>
                                    @if (!string.IsNullOrEmpty(review.CustomerEmail))
                                    {
                                        <small class="text-muted">@review.CustomerEmail</small>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= review.Rating)
                                            {
                                                <span style="color: #ffc107;">★</span>
                                            }
                                            else
                                            {
                                                <span style="color: #ddd;">★</span>
                                            }
                                        }
                                        <span class="ms-2">@review.Rating/5</span>
                                    </div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(review.Comment))
                                    {
                                        <div style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@review.Comment">
                                            @review.Comment
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(review.Images))
                                    {
                                        var images = review.Images.Split(',', StringSplitOptions.RemoveEmptyEntries);
                                        <div class="d-flex gap-1">
                                            @foreach (var img in images.Take(3))
                                            {
                                                <img src="@img.Trim()" alt="Review image" style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px; cursor: pointer;" 
                                                     onclick="showImageModal('@img.Trim()')">
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <select class="form-select form-select-sm status-select" data-review-id="@review.Id" style="width: auto; display: inline-block;">
                                        @if (review.Status == "approved")
                                        {
                                            <option value="approved" selected>Đã duyệt</option>
                                        }
                                        else
                                        {
                                            <option value="approved">Đã duyệt</option>
                                        }
                                        @if (review.Status == "pending")
                                        {
                                            <option value="pending" selected>Chờ duyệt</option>
                                        }
                                        else
                                        {
                                            <option value="pending">Chờ duyệt</option>
                                        }
                                        @if (review.Status == "rejected")
                                        {
                                            <option value="rejected" selected>Từ chối</option>
                                        }
                                        else
                                        {
                                            <option value="rejected">Từ chối</option>
                                        }
                                    </select>
                                </td>
                                <td>@review.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <button class="btn btn-sm btn-danger" onclick="deleteReview(@review.Id)">
                                        <i class="bi bi-trash"></i> Xóa
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            <p class="mb-0">Không có đánh giá nào.</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.status-select').forEach(select => {
            select.addEventListener('change', async function() {
                const reviewId = this.dataset.reviewId;
                const newStatus = this.value;
                const oldValue = this.options[this.selectedIndex].text;

                if (confirm(`Bạn có chắc muốn đổi trạng thái đánh giá #${reviewId} thành "${newStatus}"?`)) {
                    try {
                        const response = await fetch('@Url.Action("UpdateStatus", "Admin/ProductReview")', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                            },
                            body: JSON.stringify({ reviewId: parseInt(reviewId), status: newStatus })
                        });

                        const result = await response.json();
                        if (result.success) {
                            location.reload();
                        } else {
                            alert('Lỗi: ' + result.message);
                            this.value = oldValue;
                        }
                    } catch (error) {
                        alert('Có lỗi xảy ra: ' + error.message);
                        this.value = oldValue;
                    }
                } else {
                    this.value = oldValue;
                }
            });
        });

        async function deleteReview(reviewId) {
            if (confirm('Bạn có chắc muốn xóa đánh giá này?')) {
                try {
                    const response = await fetch(`@Url.Action("Delete", "Admin/ProductReview")/${reviewId}`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        }
                    });

                    const result = await response.json();
                    if (result.success) {
                        location.reload();
                    } else {
                        alert('Lỗi: ' + result.message);
                    }
                } catch (error) {
                    alert('Có lỗi xảy ra: ' + error.message);
                }
            }
        }

        function showImageModal(imageUrl) {
            const modal = document.createElement('div');
            modal.style.cssText = 'position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); z-index: 9999; display: flex; align-items: center; justify-content: center; cursor: pointer;';
            modal.innerHTML = `<img src="${imageUrl}" style="max-width: 90%; max-height: 90%; object-fit: contain;">`;
            modal.onclick = () => modal.remove();
            document.body.appendChild(modal);
        }
    </script>
}


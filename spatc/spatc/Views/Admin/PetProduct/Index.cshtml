@model IEnumerable<spatc.Models.PetProduct>
@{
    ViewData["Title"] = "Quản lý Thú Cưng Bán";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>Quản lý Thú Cưng Bán</h2>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Thêm thú cưng mới
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Tên thú cưng</th>
                            <th>Giống loài</th>
                            <th>Tuổi</th>
                            <th>Giới tính</th>
                            <th>Tình trạng sức khỏe</th>
                            <th>Giá bán</th>
                            <th>Hình ảnh</th>
                            <th>Trạng thái</th>
                            <th>Ngày tạo</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.Name</td>
                                <td><span class="badge bg-info">@item.Species</span></td>
                                <td>@item.Age</td>
                                <td>@item.Gender</td>
                                <td>@item.HealthStatus</td>
                                <td class="fw-bold text-primary">@item.Price.ToString("N0") đ</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Images))
                                    {
                                        var images = item.Images.Split(',', StringSplitOptions.RemoveEmptyEntries);
                                        if (images.Length > 0)
                                        {
                                            <img src="@images[0].Trim()" alt="@item.Name" style="width: 50px; height: 50px; object-fit: cover;" class="rounded">
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">Chưa có</span>
                                    }
                                </td>
                                <td>
                                    @if (item.TrangThai)
                                    {
                                        <span class="badge bg-success">Còn bán</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Đã bán</span>
                                    }
                                </td>
                                <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-sm btn-info">
                                        <i class="bi bi-search"></i> Chi tiết
                                    </a>
                                    <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i> Sửa
                                    </a>
                                    <a href="@Url.Action("Delete", new { id = item.Id })" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


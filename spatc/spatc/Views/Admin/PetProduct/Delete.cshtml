@model spatc.Models.PetProduct
@{
    ViewData["Title"] = "Xóa thú cưng";
}

<div class="container mt-4">
    <h2>Xóa thú cưng</h2>
    <hr />
    <h3>Bạn có chắc chắn muốn xóa thú cưng này?</h3>

    <div class="row">
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-3">Tên thú cưng:</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Giống loài:</dt>
                <dd class="col-sm-9">@Model.Species</dd>

                <dt class="col-sm-3">Giá bán:</dt>
                <dd class="col-sm-9">@Model.Price.ToString("N0") đ</dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Xóa</button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">Quay lại</a>
            </form>
        </div>
    </div>
</div>


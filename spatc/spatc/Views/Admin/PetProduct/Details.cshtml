@model spatc.Models.PetProduct
@{
    ViewData["Title"] = "Chi tiết thú cưng";
}

<div class="container mt-4">
    <h2>Chi tiết thú cưng</h2>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-3">Tên thú cưng:</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Giống loài:</dt>
                <dd class="col-sm-9"><span class="badge bg-info">@Model.Species</span></dd>

                <dt class="col-sm-3">Tuổi:</dt>
                <dd class="col-sm-9">@(Model.Age ?? "Chưa cập nhật")</dd>

                <dt class="col-sm-3">Giới tính:</dt>
                <dd class="col-sm-9">@(Model.Gender ?? "Chưa cập nhật")</dd>

                <dt class="col-sm-3">Tình trạng sức khỏe:</dt>
                <dd class="col-sm-9">@(Model.HealthStatus ?? "Chưa cập nhật")</dd>

                <dt class="col-sm-3">Giá bán:</dt>
                <dd class="col-sm-9"><strong class="text-primary">@Model.Price.ToString("N0") đ</strong></dd>

                <dt class="col-sm-3">Mô tả:</dt>
                <dd class="col-sm-9">@Html.Raw(Model.Description?.Replace("\n", "<br>") ?? "Chưa có mô tả")</dd>

                <dt class="col-sm-3">Hình ảnh:</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.Images))
                    {
                        var images = Model.Images.Split(',', StringSplitOptions.RemoveEmptyEntries);
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var img in images)
                            {
                                <img src="@img.Trim()" alt="@Model.Name" class="img-fluid rounded border" style="max-width: 200px; max-height: 200px; object-fit: cover;">
                            }
                        </div>
                    }
                    else
                    {
                        <span class="text-muted">Chưa có hình ảnh</span>
                    }
                </dd>

                <dt class="col-sm-3">Trạng thái:</dt>
                <dd class="col-sm-9">
                    @if (Model.TrangThai)
                    {
                        <span class="badge bg-success">Còn bán</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Đã bán</span>
                    }
                </dd>

                <dt class="col-sm-3">Ngày tạo:</dt>
                <dd class="col-sm-9">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

                <dt class="col-sm-3">Ngày cập nhật:</dt>
                <dd class="col-sm-9">@Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
            </dl>

            <div class="mt-4">
                <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-warning">Sửa</a>
                <a href="@Url.Action("Index")" class="btn btn-secondary">Quay lại</a>
            </div>
        </div>
    </div>
</div>


@model spatc.Models.Voucher
@{
    ViewData["Title"] = "Thêm voucher mới";
}

<div class="container mt-4">
    <h2>Thêm voucher mới</h2>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="mb-3">
                    <label asp-for="Code" class="form-label">Mã voucher *</label>
                    <input asp-for="Code" class="form-control" placeholder="VD: SALE10" />
                    <span asp-validation-for="Code" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Type" class="form-label">Loại giảm giá *</label>
                            <select asp-for="Type" class="form-select" id="voucherType" required>
                                <option value="percent">Giảm theo phần trăm (%)</option>
                                <option value="cash">Giảm theo số tiền (VNĐ)</option>
                            </select>
                            <span asp-validation-for="Type" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Value" class="form-label">Giá trị *</label>
                            <input asp-for="Value" class="form-control" type="number" step="0.01" min="0" id="voucherValue" />
                            <small class="text-muted" id="valueHint">Nhập phần trăm (VD: 10 = 10%)</small>
                            <span asp-validation-for="Value" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="MinOrderAmount" class="form-label">Đơn hàng tối thiểu</label>
                            <input asp-for="MinOrderAmount" class="form-control" type="number" step="0.01" min="0" value="0" />
                            <span asp-validation-for="MinOrderAmount" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="MaxDiscount" class="form-label">Giảm tối đa (chỉ áp dụng cho %)</label>
                            <input asp-for="MaxDiscount" class="form-control" type="number" step="0.01" min="0" id="maxDiscount" />
                            <span asp-validation-for="MaxDiscount" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="StartDate" class="form-label">Ngày bắt đầu</label>
                            <input asp-for="StartDate" class="form-control" type="datetime-local" />
                            <span asp-validation-for="StartDate" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="EndDate" class="form-label">Ngày kết thúc *</label>
                            <input asp-for="EndDate" class="form-control" type="datetime-local" required />
                            <span asp-validation-for="EndDate" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="form-check">
                        <input asp-for="Status" class="form-check-input" type="checkbox" value="active" checked />
                        <label asp-for="Status" class="form-check-label">Hoạt động</label>
                    </div>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Thêm mới</button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('voucherType').addEventListener('change', function() {
            const hint = document.getElementById('valueHint');
            const maxDiscount = document.getElementById('maxDiscount').parentElement;
            if (this.value === 'percent') {
                hint.textContent = 'Nhập phần trăm (VD: 10 = 10%)';
                maxDiscount.style.display = 'block';
            } else {
                hint.textContent = 'Nhập số tiền giảm (VD: 50000 = 50.000 đ)';
                maxDiscount.style.display = 'none';
            }
        });
    </script>
}


@model spatc.Models.Voucher
@{
    ViewData["Title"] = "Xóa voucher";
}

<div class="container mt-4">
    <h2>Xóa voucher</h2>
    <hr />
    <h3>Bạn có chắc chắn muốn xóa voucher này?</h3>

    <div class="row">
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-3">Mã voucher:</dt>
                <dd class="col-sm-9"><strong>@Model.Code</strong></dd>

                <dt class="col-sm-3">Loại:</dt>
                <dd class="col-sm-9">
                    @if (Model.Type == "percent")
                    {
                        <span>Giảm @Model.Value%</span>
                    }
                    else
                    {
                        <span>Giảm @Model.Value.ToString("N0") đ</span>
                    }
                </dd>

                <dt class="col-sm-3">Ngày kết thúc:</dt>
                <dd class="col-sm-9">@Model.EndDate.ToString("dd/MM/yyyy")</dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Xóa</button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">Quay lại</a>
            </form>
        </div>
    </div>
</div>


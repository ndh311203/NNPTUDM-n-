@model spatc.Models.ShopOrder
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.Id;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Chi tiết đơn hàng #@Model.Id</h2>
        <a href="@Url.Action("Index")" class="btn btn-secondary">← Quay lại</a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Sản phẩm đã mua</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th>Loại</th>
                                    <th>Số lượng</th>
                                    <th>Đơn giá</th>
                                    <th>Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.ShopOrderItems != null)
                                {
                                    @foreach (var item in Model.ShopOrderItems)
                                    {
                                        <tr>
                                            <td>@item.ProductName</td>
                                            <td>
                                                @if (item.ProductType == "pet")
                                                {
                                                    <span class="badge bg-primary">🐕 Thú cưng</span>
                                                }
                                                else if (item.ProductType == "food")
                                                {
                                                    <span class="badge bg-success">🍖 Thức ăn</span>
                                                }
                                                else if (item.ProductType == "accessory")
                                                {
                                                    <span class="badge bg-info">🎁 Phụ kiện</span>
                                                }
                                            </td>
                                            <td>@item.Quantity</td>
                                            <td>@item.Price.ToString("N0") đ</td>
                                            <td class="fw-bold">@((item.Price * item.Quantity).ToString("N0")) đ</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="4" class="text-end"><strong>Tổng tiền:</strong></td>
                                    <td class="fw-bold text-primary fs-5">@Model.TotalAmount.ToString("N0") đ</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Thông tin khách hàng</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-5">Họ tên:</dt>
                        <dd class="col-sm-7">@Model.CustomerName</dd>

                        <dt class="col-sm-5">Số điện thoại:</dt>
                        <dd class="col-sm-7">@Model.Phone</dd>

                        @if (!string.IsNullOrEmpty(Model.Email))
                        {
                            <dt class="col-sm-5">Email:</dt>
                            <dd class="col-sm-7">@Model.Email</dd>
                        }

                        <dt class="col-sm-5">Địa chỉ:</dt>
                        <dd class="col-sm-7">@Model.Address</dd>

                        @if (!string.IsNullOrEmpty(Model.Note))
                        {
                            <dt class="col-sm-5">Ghi chú:</dt>
                            <dd class="col-sm-7">@Model.Note</dd>
                        }
                    </dl>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Thông tin đơn hàng</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-6">Mã đơn hàng:</dt>
                        <dd class="col-sm-6"><strong>#@Model.Id</strong></dd>

                        <dt class="col-sm-6">Phương thức thanh toán:</dt>
                        <dd class="col-sm-6">
                            @if (Model.PaymentMethod == "COD")
                            {
                                <span class="badge bg-warning">💵 COD</span>
                            }
                            else if (Model.PaymentMethod == "VietQR")
                            {
                                <span class="badge bg-primary">📱 VietQR</span>
                            }
                            else
                            {
                                <span class="badge bg-info">🏦 Chuyển khoản</span>
                            }
                        </dd>

                        @if (!string.IsNullOrEmpty(Model.PaymentStatus))
                        {
                            <dt class="col-sm-6">Trạng thái thanh toán:</dt>
                            <dd class="col-sm-6">
                                <select class="form-select form-select-sm payment-status-select" data-order-id="@Model.Id">
                                    @if (Model.PaymentStatus == "waiting_payment")
                                    {
                                        <option value="waiting_payment" selected>Chờ thanh toán</option>
                                    }
                                    else
                                    {
                                        <option value="waiting_payment">Chờ thanh toán</option>
                                    }
                                    @if (Model.PaymentStatus == "Paid")
                                    {
                                        <option value="Paid" selected>Đã thanh toán</option>
                                    }
                                    else
                                    {
                                        <option value="Paid">Đã thanh toán</option>
                                    }
                                    @if (Model.PaymentStatus == "Canceled")
                                    {
                                        <option value="Canceled" selected>Đã hủy</option>
                                    }
                                    else
                                    {
                                        <option value="Canceled">Đã hủy</option>
                                    }
                                    @if (Model.PaymentStatus == "Failed")
                                    {
                                        <option value="Failed" selected>Thanh toán thất bại</option>
                                    }
                                    else
                                    {
                                        <option value="Failed">Thanh toán thất bại</option>
                                    }
                                </select>
                            </dd>
                        }

                        @if (!string.IsNullOrEmpty(Model.VoucherCode))
                        {
                            <dt class="col-sm-6">Mã voucher:</dt>
                            <dd class="col-sm-6"><span class="badge bg-success">@Model.VoucherCode</span></dd>

                            @if (Model.DiscountAmount > 0)
                            {
                                <dt class="col-sm-6">Giảm giá:</dt>
                                <dd class="col-sm-6"><span class="text-success">-@Model.DiscountAmount.ToString("N0") đ</span></dd>
                            }
                        }

                        <dt class="col-sm-6">Trạng thái:</dt>
                        <dd class="col-sm-6">
                            <select class="form-select form-select-sm status-select" data-order-id="@Model.Id">
                                @if (Model.Status == "Chờ xác nhận")
                                {
                                    <option value="Chờ xác nhận" selected>Chờ xác nhận</option>
                                }
                                else
                                {
                                    <option value="Chờ xác nhận">Chờ xác nhận</option>
                                }
                                @if (Model.Status == "Đang giao")
                                {
                                    <option value="Đang giao" selected>Đang giao</option>
                                }
                                else
                                {
                                    <option value="Đang giao">Đang giao</option>
                                }
                                @if (Model.Status == "Hoàn thành")
                                {
                                    <option value="Hoàn thành" selected>Hoàn thành</option>
                                }
                                else
                                {
                                    <option value="Hoàn thành">Hoàn thành</option>
                                }
                                @if (Model.Status == "Hủy")
                                {
                                    <option value="Hủy" selected>Hủy</option>
                                }
                                else
                                {
                                    <option value="Hủy">Hủy</option>
                                }
                            </select>
                        </dd>

                        <dt class="col-sm-6">Ngày đặt:</dt>
                        <dd class="col-sm-6">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

                        <dt class="col-sm-6">Ngày cập nhật:</dt>
                        <dd class="col-sm-6">@Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

                        <dt class="col-sm-6">Tổng tiền:</dt>
                        <dd class="col-sm-6"><strong class="text-primary fs-5">@Model.TotalAmount.ToString("N0") đ</strong></dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelector('.status-select')?.addEventListener('change', async function() {
            const orderId = this.dataset.orderId;
            const newStatus = this.value;
            const oldValue = this.value; // Lưu giá trị cũ

            if (confirm(`Bạn có chắc muốn đổi trạng thái đơn hàng #${orderId} thành "${newStatus}"?`)) {
                try {
                    const response = await fetch('/Admin/ShopOrder/UpdateStatus', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({ orderId: parseInt(orderId), status: newStatus })
                    });

                    // Kiểm tra response status trước khi parse JSON
                    if (!response.ok) {
                        const text = await response.text();
                        throw new Error(`HTTP ${response.status}: ${text}`);
                    }

                    // Kiểm tra content type
                    const contentType = response.headers.get("content-type");
                    if (!contentType || !contentType.includes("application/json")) {
                        const text = await response.text();
                        throw new Error(`Response không phải JSON: ${text.substring(0, 100)}`);
                    }

                    const result = await response.json();
                    if (result.success) {
                        location.reload();
                    } else {
                        alert('Lỗi: ' + result.message);
                        this.value = oldValue;
                    }
                } catch (error) {
                    console.error('Error updating status:', error);
                    alert('Có lỗi xảy ra: ' + error.message);
                    this.value = oldValue;
                }
            } else {
                this.value = oldValue;
            }
        });

        document.querySelector('.payment-status-select')?.addEventListener('change', async function() {
            const orderId = this.dataset.orderId;
            const newStatus = this.value;
            const oldValue = this.value; // Lưu giá trị cũ

            if (confirm(`Bạn có chắc muốn đổi trạng thái thanh toán đơn hàng #${orderId} thành "${newStatus}"?`)) {
                try {
                    const response = await fetch('/Admin/ShopOrder/UpdatePaymentStatus', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({ orderId: parseInt(orderId), paymentStatus: newStatus })
                    });

                    // Kiểm tra response status trước khi parse JSON
                    if (!response.ok) {
                        const text = await response.text();
                        throw new Error(`HTTP ${response.status}: ${text}`);
                    }

                    // Kiểm tra content type
                    const contentType = response.headers.get("content-type");
                    if (!contentType || !contentType.includes("application/json")) {
                        const text = await response.text();
                        throw new Error(`Response không phải JSON: ${text.substring(0, 100)}`);
                    }

                    const result = await response.json();
                    if (result.success) {
                        location.reload();
                    } else {
                        alert('Lỗi: ' + result.message);
                        this.value = oldValue;
                    }
                } catch (error) {
                    console.error('Error updating payment status:', error);
                    alert('Có lỗi xảy ra: ' + error.message);
                    this.value = oldValue;
                }
            } else {
                this.value = oldValue;
            }
        });
    </script>
}


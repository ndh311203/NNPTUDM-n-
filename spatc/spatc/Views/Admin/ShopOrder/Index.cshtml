@model IEnumerable<spatc.Models.ShopOrder>
@{
    ViewData["Title"] = "Quản lý Đơn hàng Pet Shop";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Quản lý Đơn hàng Pet Shop</h2>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Bộ lọc trạng thái -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="btn-group" role="group">
                <a href="@Url.Action("Index")" class="btn @(ViewBag.StatusFilter == null ? "btn-primary" : "btn-outline-primary")">Tất cả</a>
                @foreach (var status in ViewBag.Statuses as string[])
                {
                    <a href="@Url.Action("Index", new { status = status })" class="btn @(ViewBag.StatusFilter == status ? "btn-primary" : "btn-outline-primary")">
                        @status
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Mã đơn hàng</th>
                            <th>Khách hàng</th>
                            <th>Sản phẩm đã mua</th>
                            <th>Tổng tiền</th>
                            <th>Phương thức thanh toán</th>
                            <th>Trạng thái</th>
                            <th>Ngày đặt</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td><strong>#@order.Id</strong></td>
                                <td>
                                    <div>@order.CustomerName</div>
                                    <small class="text-muted">@order.Phone</small>
                                </td>
                                <td>
                                    @if (order.ShopOrderItems != null && order.ShopOrderItems.Any())
                                    {
                                        <div>
                                            @foreach (var item in order.ShopOrderItems.Take(3))
                                            {
                                                <div class="small">@item.ProductName (x@item.Quantity)</div>
                                            }
                                            @if (order.ShopOrderItems.Count > 3)
                                            {
                                                <div class="small text-muted">... và @(order.ShopOrderItems.Count - 3) sản phẩm khác</div>
                                            }
                                        </div>
                                    }
                                </td>
                                <td class="fw-bold text-primary">@order.TotalAmount.ToString("N0") đ</td>
                                <td>
                                    @if (order.PaymentMethod == "COD")
                                    {
                                        <span class="badge bg-warning">💵 COD</span>
                                    }
                                    else if (order.PaymentMethod == "VietQR")
                                    {
                                        <span class="badge bg-primary">📱 VietQR</span>
                                        @if (!string.IsNullOrEmpty(order.PaymentStatus))
                                        {
                                            <br><small class="text-muted">
                                                @(order.PaymentStatus == "waiting_payment" ? "⏳ Chờ thanh toán" :
                                                  order.PaymentStatus == "Paid" ? "✅ Đã thanh toán" :
                                                  order.PaymentStatus == "Canceled" ? "❌ Đã hủy" :
                                                  order.PaymentStatus == "Failed" ? "⚠️ Thất bại" : "")
                                            </small>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">🏦 Chuyển khoản</span>
                                    }
                                </td>
                                <td>
                                    <select class="form-select form-select-sm status-select" data-order-id="@order.Id" style="width: auto; display: inline-block;">
                                        @if (order.Status == "Chờ xác nhận")
                                        {
                                            <option value="Chờ xác nhận" selected>Chờ xác nhận</option>
                                        }
                                        else
                                        {
                                            <option value="Chờ xác nhận">Chờ xác nhận</option>
                                        }
                                        @if (order.Status == "Đang giao")
                                        {
                                            <option value="Đang giao" selected>Đang giao</option>
                                        }
                                        else
                                        {
                                            <option value="Đang giao">Đang giao</option>
                                        }
                                        @if (order.Status == "Hoàn thành")
                                        {
                                            <option value="Hoàn thành" selected>Hoàn thành</option>
                                        }
                                        else
                                        {
                                            <option value="Hoàn thành">Hoàn thành</option>
                                        }
                                        @if (order.Status == "Hủy")
                                        {
                                            <option value="Hủy" selected>Hủy</option>
                                        }
                                        else
                                        {
                                            <option value="Hủy">Hủy</option>
                                        }
                                    </select>
                                </td>
                                <td>@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <a href="@Url.Action("Details", new { id = order.Id })" class="btn btn-sm btn-info">
                                        <i class="bi bi-search"></i> Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            <p class="mb-0">Không có đơn hàng nào.</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.status-select').forEach(select => {
            select.addEventListener('change', async function() {
                const orderId = this.dataset.orderId;
                const newStatus = this.value;
                const oldValue = this.value; // Lưu giá trị cũ

                if (confirm(`Bạn có chắc muốn đổi trạng thái đơn hàng #${orderId} thành "${newStatus}"?`)) {
                    try {
                        const response = await fetch('/Admin/ShopOrder/UpdateStatus', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                            },
                            body: JSON.stringify({ orderId: parseInt(orderId), status: newStatus })
                        });

                        // Kiểm tra response status trước khi parse JSON
                        if (!response.ok) {
                            const text = await response.text();
                            throw new Error(`HTTP ${response.status}: ${text}`);
                        }

                        // Kiểm tra content type
                        const contentType = response.headers.get("content-type");
                        if (!contentType || !contentType.includes("application/json")) {
                            const text = await response.text();
                            throw new Error(`Response không phải JSON: ${text.substring(0, 100)}`);
                        }

                        const result = await response.json();
                        if (result.success) {
                            location.reload();
                        } else {
                            alert('Lỗi: ' + result.message);
                            this.value = oldValue;
                        }
                    } catch (error) {
                        console.error('Error updating status:', error);
                        alert('Có lỗi xảy ra: ' + error.message);
                        this.value = oldValue;
                    }
                } else {
                    this.value = oldValue;
                }
            });
        });
    </script>
}


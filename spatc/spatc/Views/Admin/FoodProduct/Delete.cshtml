@model spatc.Models.FoodProduct
@{
    ViewData["Title"] = "Xóa thức ăn";
}

<div class="container mt-4">
    <h2>Xóa thức ăn</h2>
    <hr />
    <h3>Bạn có chắc chắn muốn xóa thức ăn này?</h3>

    <div class="row">
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-3">Tên sản phẩm:</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Loại thức ăn:</dt>
                <dd class="col-sm-9">@Model.Type</dd>

                <dt class="col-sm-3">Giá bán:</dt>
                <dd class="col-sm-9">@Model.Price.ToString("N0") đ</dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Xóa</button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">Quay lại</a>
            </form>
        </div>
    </div>
</div>


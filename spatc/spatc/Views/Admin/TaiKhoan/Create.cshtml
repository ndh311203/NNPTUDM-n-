@model spatc.Models.TaiKhoan
@{
    ViewData["Title"] = "Thêm tài khoản mới";
}

<div class="container mt-4">
    <h2>Thêm tài khoản mới</h2>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email *</label>
                    <input asp-for="Email" class="form-control" type="email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label for="matKhau" class="form-label">Mật khẩu *</label>
                    <input name="matKhau" id="matKhau" class="form-control" type="password" required />
                    <span class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="HoTen" class="form-label">Họ tên</label>
                    <input asp-for="HoTen" class="form-control" />
                    <span asp-validation-for="HoTen" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="VaiTro" class="form-label">Vai trò *</label>
                    <select asp-for="VaiTro" class="form-select" required>
                        <option value="Admin">Admin</option>
                        <option value="NhanVien">Nhân viên</option>
                        <option value="User">Người dùng</option>
                    </select>
                    <span asp-validation-for="VaiTro" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <div class="form-check">
                        <input asp-for="TrangThai" class="form-check-input" type="checkbox" checked />
                        <label asp-for="TrangThai" class="form-check-label">Hoạt động</label>
                    </div>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Thêm mới</button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}


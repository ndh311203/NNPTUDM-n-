@model IEnumerable<spatc.Models.TaiKhoan>
@{
    ViewData["Title"] = "Quản lý Tài khoản";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Quản lý Tài khoản</h2>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Thêm tài khoản mới
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Email</th>
                            <th>Họ tên</th>
                            <th>Vai trò</th>
                            <th>Đăng nhập</th>
                            <th>Trạng thái</th>
                            <th>Ngày tạo</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.Email</td>
                                <td>@(item.HoTen ?? "-")</td>
                                <td>
                                    @if (item.VaiTro == "Admin")
                                    {
                                        <span class="badge bg-danger">Admin</span>
                                    }
                                    else if (item.VaiTro == "NhanVien")
                                    {
                                        <span class="badge bg-primary">Nhân viên</span>
                                    }
                                    else if (item.VaiTro == "User")
                                    {
                                        <span class="badge bg-info">Người dùng</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@item.VaiTro</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Provider == "Google")
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-google"></i> Google</span>
                                    }
                                    else if (item.Provider == "Facebook")
                                    {
                                        <span class="badge bg-primary"><i class="bi bi-facebook"></i> Facebook</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Local</span>
                                    }
                                </td>
                                <td>
                                    @if (item.TrangThai)
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Khóa</span>
                                    }
                                </td>
                                <td>@item.NgayTao.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-sm btn-info">
                                        <i class="bi bi-search"></i> Chi tiết
                                    </a>
                                    <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i> Sửa
                                    </a>
                                    <a href="@Url.Action("Delete", new { id = item.Id })" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


@model spatc.Models.DichVu
@{
    ViewData["Title"] = "Xóa dịch vụ Grooming";
}

<div class="container mt-4">
    <h2>Xóa dịch vụ Grooming</h2>
    <hr />
    <h3 class="text-danger">Bạn có chắc chắn muốn xóa dịch vụ này?</h3>

    <div class="row">
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-3">Tên dịch vụ:</dt>
                <dd class="col-sm-9">@Model.TenDichVu</dd>

                <dt class="col-sm-3">Loại dịch vụ:</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-info">✂️ Grooming</span>
                </dd>

                <dt class="col-sm-3">Giá:</dt>
                <dd class="col-sm-9">@Model.Gia.ToString("N0") đ</dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Xóa</button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">Quay lại</a>
            </form>
        </div>
    </div>
</div>

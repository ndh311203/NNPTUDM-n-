@model spatc.Models.DichVu
@{
    ViewData["Title"] = "Sửa dịch vụ Grooming";
}

<div class="container mt-4">
    <h2>✂️ Sửa dịch vụ Grooming</h2>
    <hr />

    <div class="row">
        <div class="col-md-10">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="NgayTao" />
                <input type="hidden" asp-for="LoaiDichVu" />
                
                <div class="card mb-3">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Thông tin cơ bản</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="TenDichVu" class="form-label">Tên dịch vụ *</label>
                            <input asp-for="TenDichVu" class="form-control" placeholder="VD: Tắm thú cưng, Cắt lông, Spa toàn thân, Vệ sinh tai – cắt móng" />
                            <span asp-validation-for="TenDichVu" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Gia" class="form-label">Giá (VNĐ) *</label>
                            <input asp-for="Gia" class="form-control" type="number" step="0.01" min="0" placeholder="VD: 100000 - 500000" />
                            <small class="form-text text-muted">VD: 100.000đ – 500.000đ tuỳ gói</small>
                            <span asp-validation-for="Gia" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MoTa" class="form-label">Mô tả chi tiết gói dịch vụ *</label>
                            <textarea asp-for="MoTa" class="form-control" rows="5" placeholder="VD: Bao gồm tắm, sấy, chải lông, khử mùi, cắt móng, vệ sinh tai..."></textarea>
                            <small class="form-text text-muted">Mô tả chi tiết những gì được bao gồm trong gói dịch vụ</small>
                            <span asp-validation-for="MoTa" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">Chi tiết dịch vụ</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ThoiGianThucHien" class="form-label">Thời gian thực hiện (phút)</label>
                                <input asp-for="ThoiGianThucHien" class="form-control" type="number" min="0" placeholder="VD: 30-60 phút" />
                                <small class="form-text text-muted">Thời gian ước tính để hoàn thành dịch vụ</small>
                                <span asp-validation-for="ThoiGianThucHien" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="KichThuocThuCung" class="form-label">Kích thước thú cưng</label>
                                <select asp-for="KichThuocThuCung" class="form-select">
                                    <option value="">-- Chọn kích thước --</option>
                                    <option value="Nhỏ">🐾 Nhỏ (dưới 10kg)</option>
                                    <option value="Trung">🐕 Trung (10-25kg)</option>
                                    <option value="Lớn">🐕‍🦺 Lớn (trên 25kg)</option>
                                </select>
                                <small class="form-text text-muted">Phân loại theo kích thước thú cưng</small>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">Hình ảnh & Trạng thái</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="HinhAnh" class="form-label">URL Hình ảnh minh họa</label>
                            <input asp-for="HinhAnh" class="form-control" placeholder="https://..." />
                            <small class="form-text text-muted">Link hình ảnh minh họa dịch vụ</small>
                            <span asp-validation-for="HinhAnh" class="text-danger"></span>
                            @if (!string.IsNullOrEmpty(Model.HinhAnh))
                            {
                                <div class="mt-2">
                                    <img src="@Model.HinhAnh" alt="@Model.TenDichVu" class="img-thumbnail" style="max-width: 200px;">
                                </div>
                            }
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input asp-for="TrangThai" class="form-check-input" type="checkbox" />
                                <label asp-for="TrangThai" class="form-check-label">Hoạt động</label>
                                <small class="form-text text-muted d-block">Dịch vụ sẽ hiển thị ở trang công khai</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle"></i> Cập nhật
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

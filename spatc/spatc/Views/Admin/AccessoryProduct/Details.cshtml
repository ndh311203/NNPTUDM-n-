@model spatc.Models.AccessoryProduct
@{
    ViewData["Title"] = "Chi tiết phụ kiện";
}

<div class="container mt-4">
    <h2>Chi tiết phụ kiện</h2>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-3">Tên sản phẩm:</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Phân loại:</dt>
                <dd class="col-sm-9"><span class="badge bg-info">@Model.Category</span></dd>

                <dt class="col-sm-3">Chất liệu:</dt>
                <dd class="col-sm-9">@(Model.Material ?? "N/A")</dd>

                <dt class="col-sm-3">Giá bán:</dt>
                <dd class="col-sm-9"><strong class="text-primary">@Model.Price.ToString("N0") đ</strong></dd>

                <dt class="col-sm-3">Mô tả:</dt>
                <dd class="col-sm-9">@Html.Raw(Model.Description?.Replace("\n", "<br>") ?? "Chưa có mô tả")</dd>

                <dt class="col-sm-3">Hình ảnh:</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.Image))
                    {
                        <img src="@Model.Image" alt="@Model.Name" class="img-fluid rounded border" style="max-width: 300px;">
                    }
                    else
                    {
                        <span class="text-muted">Chưa có hình ảnh</span>
                    }
                </dd>

                <dt class="col-sm-3">Số lượng tồn kho:</dt>
                <dd class="col-sm-9">@Model.SoLuongTon</dd>

                <dt class="col-sm-3">Trạng thái:</dt>
                <dd class="col-sm-9">
                    @if (Model.TrangThai)
                    {
                        <span class="badge bg-success">Còn hàng</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Hết hàng</span>
                    }
                </dd>

                <dt class="col-sm-3">Ngày tạo:</dt>
                <dd class="col-sm-9">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

                <dt class="col-sm-3">Ngày cập nhật:</dt>
                <dd class="col-sm-9">@Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
            </dl>

            <div class="mt-4">
                <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-warning">Sửa</a>
                <a href="@Url.Action("Index")" class="btn btn-secondary">Quay lại</a>
            </div>
        </div>
    </div>
</div>


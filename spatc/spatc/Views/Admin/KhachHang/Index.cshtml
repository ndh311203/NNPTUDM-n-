@model IEnumerable<spatc.Models.KhachHang>
@{
    ViewData["Title"] = "Quản lý Khách hàng";
}

<div class="container-fluid mt-4">
    <h2>Quản lý Khách hàng</h2>
    <hr />

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Họ tên</th>
                            <th>Số điện thoại</th>
                            <th>Email</th>
                            <th>Địa chỉ</th>
                            <th>Số thú cưng</th>
                            <th>Ngày tạo</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.HoTen</td>
                                <td>@item.SoDienThoai</td>
                                <td>@(item.Email ?? "-")</td>
                                <td>@(item.DiaChi ?? "-")</td>
                                <td><span class="badge bg-info">@(item.ThuCungs?.Count ?? 0)</span></td>
                                <td>@item.NgayTao.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-sm btn-info">
                                        <i class="bi bi-search"></i> Chi tiết
                                    </a>
                                    <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i> Sửa
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


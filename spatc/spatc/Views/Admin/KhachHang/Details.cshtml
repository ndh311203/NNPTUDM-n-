@model spatc.Models.KhachHang
@{
    ViewData["Title"] = "Chi tiết khách hàng";
}

<div class="container mt-4">
    <h2>Chi tiết khách hàng</h2>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-3">Họ tên:</dt>
                <dd class="col-sm-9">@Model.HoTen</dd>

                <dt class="col-sm-3">Số điện thoại:</dt>
                <dd class="col-sm-9">@Model.SoDienThoai</dd>

                <dt class="col-sm-3">Email:</dt>
                <dd class="col-sm-9">@(Model.Email ?? "-")</dd>

                <dt class="col-sm-3">Địa chỉ:</dt>
                <dd class="col-sm-9">@(Model.DiaChi ?? "-")</dd>

                <dt class="col-sm-3">Ghi chú:</dt>
                <dd class="col-sm-9">@(Model.GhiChu ?? "-")</dd>

                <dt class="col-sm-3">Ngày tạo:</dt>
                <dd class="col-sm-9">@Model.NgayTao.ToString("dd/MM/yyyy")</dd>
            </dl>

            <h4 class="mt-4">Danh sách thú cưng</h4>
            @if (Model.ThuCungs != null && Model.ThuCungs.Any())
            {
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Tên</th>
                            <th>Loại</th>
                            <th>Giống</th>
                            <th>Tuổi</th>
                            <th>Cân nặng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tc in Model.ThuCungs)
                        {
                            <tr>
                                <td>@tc.TenThuCung</td>
                                <td>@tc.Loai</td>
                                <td>@(tc.Giong ?? "-")</td>
                                <td>@(tc.Tuoi?.ToString() ?? "-")</td>
                                <td>@(tc.CanNang?.ToString() ?? "-") kg</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted">Chưa có thú cưng</p>
            }

            <div class="mt-4">
                <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-warning">Sửa</a>
                <a href="@Url.Action("Index")" class="btn btn-secondary">Quay lại</a>
            </div>
        </div>
    </div>
</div>


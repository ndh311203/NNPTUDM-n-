@{
    ViewData["Title"] = "Debug Thông báo";
    var recentNotifications = ViewBag.RecentNotifications as List<spatc.Models.ThongBao>;
    var recentBookings = ViewBag.RecentBookings as List<spatc.Models.DatLich>;
}

<div class="container mt-4">
    <h2>🔍 Debug Hệ thống Thông báo</h2>
    <hr />

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5>Kiểm tra nhanh</h5>
                </div>
                <div class="card-body">
                    <button type="button" class="btn btn-primary" onclick="testCreateNotification()">
                        <i class="bi bi-bell"></i> Tạo thông báo test
                    </button>
                    <button type="button" class="btn btn-info" onclick="checkSignalRConnection()">
                        <i class="bi bi-wifi"></i> Kiểm tra SignalR
                    </button>
                    <button type="button" class="btn btn-success" onclick="loadNotifications()">
                        <i class="bi bi-arrow-clockwise"></i> Tải lại thông báo
                    </button>
                    <div id="debugResult" class="mt-3"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5>Thông báo gần đây (@ViewBag.TotalNotifications tổng cộng)</h5>
                </div>
                <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                    @if (recentNotifications != null && recentNotifications.Any())
                    {
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Loại</th>
                                    <th>Tiêu đề</th>
                                    <th>Thời gian</th>
                                    <th>Đã đọc</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var notif in recentNotifications)
                                {
                                    <tr class="@(!notif.DaDoc ? "table-warning" : "")">
                                        <td>@notif.Id</td>
                                        <td><small>@notif.LoaiThongBao</small></td>
                                        <td>@notif.TieuDe</td>
                                        <td>@notif.ThoiGianTao.ToString("HH:mm:ss")</td>
                                        <td>@(notif.DaDoc ? "✓" : "✗")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted">Chưa có thông báo nào</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5>Đặt lịch gần đây</h5>
                </div>
                <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                    @if (recentBookings != null && recentBookings.Any())
                    {
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Khách hàng</th>
                                    <th>Thú cưng</th>
                                    <th>Thời gian</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var booking in recentBookings)
                                {
                                    <tr>
                                        <td>@booking.Id</td>
                                        <td>@(booking.ThuCung?.KhachHang?.HoTen ?? "N/A")</td>
                                        <td>@(booking.ThuCung?.TenThuCung ?? "N/A")</td>
                                        <td>@booking.ThoiGianHen.ToString("dd/MM HH:mm")</td>
                                        <td>
                                            <button class="btn btn-sm btn-warning" onclick="recreateNotification(@booking.Id)">
                                                Tạo lại TB
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted">Chưa có đặt lịch nào</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function testCreateNotification() {
            const resultDiv = document.getElementById('debugResult');
            resultDiv.innerHTML = '<div class="alert alert-info">Đang tạo thông báo test...</div>';

            fetch('/Admin/DebugNotification/TestCreate', {
                method: 'POST',
                headers: {
                    'Accept': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    resultDiv.innerHTML = `<div class="alert alert-success">
                        ✅ Đã tạo thông báo test thành công!<br>
                        ID: ${data.notificationId}<br>
                        Tiêu đề: ${data.notification.tieuDe}<br>
                        <small>Kiểm tra xem có nhận được thông báo realtime không</small>
                    </div>`;
                    // Reload sau 2 giây
                    setTimeout(() => location.reload(), 2000);
                } else {
                    resultDiv.innerHTML = `<div class="alert alert-danger">❌ Lỗi: ${data.message}</div>`;
                }
            })
            .catch(error => {
                console.error('Error:', error);
                resultDiv.innerHTML = `<div class="alert alert-danger">❌ Lỗi: ${error.message}</div>`;
            });
        }

        function recreateNotification(datLichId) {
            if (!confirm('Bạn có chắc muốn tạo lại thông báo cho đặt lịch này?')) {
                return;
            }

            fetch('/Admin/DebugNotification/RecreateForBooking', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: JSON.stringify(datLichId)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('✅ Đã tạo lại thông báo thành công!');
                    location.reload();
                } else {
                    alert('❌ Lỗi: ' + data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('❌ Có lỗi xảy ra');
            });
        }

        function checkSignalRConnection() {
            const resultDiv = document.getElementById('debugResult');
            
            // Kiểm tra xem có SignalR connection không
            if (typeof signalR === 'undefined') {
                resultDiv.innerHTML = '<div class="alert alert-danger">❌ SignalR library chưa được load!</div>';
                return;
            }

            // Kiểm tra connection
            if (window.connection && window.connection.state === signalR.HubConnectionState.Connected) {
                resultDiv.innerHTML = '<div class="alert alert-success">✅ SignalR đã kết nối! Connection ID: ' + window.connection.connectionId + '</div>';
            } else if (window.connection) {
                resultDiv.innerHTML = '<div class="alert alert-warning">⚠️ SignalR chưa kết nối. State: ' + window.connection.state + '</div>';
            } else {
                resultDiv.innerHTML = '<div class="alert alert-danger">❌ Không tìm thấy SignalR connection!</div>';
            }
        }

        function loadNotifications() {
            fetch('/api/notification?skip=0&take=20', {
                headers: {
                    'Accept': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                const resultDiv = document.getElementById('debugResult');
                if (data.success) {
                    resultDiv.innerHTML = `<div class="alert alert-success">
                        ✅ Đã tải ${data.data?.length || 0} thông báo<br>
                        Số chưa đọc: ${data.soLuongChuaDoc || 0}
                    </div>`;
                } else {
                    resultDiv.innerHTML = `<div class="alert alert-danger">❌ Lỗi: ${data.message}</div>`;
                }
            })
            .catch(error => {
                console.error('Error:', error);
                const resultDiv = document.getElementById('debugResult');
                resultDiv.innerHTML = `<div class="alert alert-danger">❌ Lỗi: ${error.message}</div>`;
            });
        }

        // Expose connection to window for debugging
        document.addEventListener('DOMContentLoaded', function() {
            // Tìm connection từ notifications.js
            setTimeout(() => {
                if (typeof connection !== 'undefined') {
                    window.connection = connection;
                }
            }, 1000);
        });
    </script>
}


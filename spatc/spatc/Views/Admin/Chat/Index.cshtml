@{
    ViewData["Title"] = "Quản lý Chat";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-4 border-end" style="height: calc(100vh - 150px); overflow-y: auto;">
            <h5 class="mb-3">Danh sách cuộc trò chuyện</h5>
            <div id="conversationsList">
                <div class="text-center text-muted">
                    <small>Đang tải...</small>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div id="chatArea" style="height: calc(100vh - 150px); display: flex; flex-direction: column;">
                <div id="chatHeaderAdmin" class="border-bottom p-3" style="display: none;">
                    <h6 id="chatUserInfo" style="margin: 0;"></h6>
                </div>
                <div id="chatMessagesAdmin" class="flex-grow-1 p-3" style="overflow-y: auto; background: #f8f9fa;">
                    <div class="text-center text-muted">
                        <small>Chọn một cuộc trò chuyện để bắt đầu</small>
                    </div>
                </div>
                <div id="chatInputAreaAdmin" class="border-top p-3" style="display: none; background: white;">
                    <div class="input-group">
                        <input type="text" id="chatInputAdmin" class="form-control" placeholder="Nhập tin nhắn...">
                        <button id="chatSendBtnAdmin" class="btn btn-primary">
                            <i class="bi bi-send"></i> Gửi
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-chat.js" asp-append-version="true"></script>
}


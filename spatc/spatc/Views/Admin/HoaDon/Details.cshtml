@model spatc.Models.HoaDon
@{
    ViewData["Title"] = "Chi tiết hóa đơn";
}

<div class="container mt-4">
    <h2>Chi tiết hóa đơn</h2>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-3">ID:</dt>
                <dd class="col-sm-9">@Model.Id</dd>

                <dt class="col-sm-3">Loại hóa đơn:</dt>
                <dd class="col-sm-9">
                    @if (Model.LoaiHoaDon == "TuDatLich")
                    {
                        <span class="badge bg-info">Từ đặt lịch</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Khách hàng đến quán</span>
                    }
                </dd>

                <dt class="col-sm-3">Ngày thanh toán:</dt>
                <dd class="col-sm-9">@Model.NgayThanhToan.ToString("dd/MM/yyyy HH:mm")</dd>

                @if (Model.LoaiHoaDon == "TuDatLich")
                {
                    <dt class="col-sm-3">Mã đặt lịch:</dt>
                    <dd class="col-sm-9">@(Model.DatLichId?.ToString() ?? "-")</dd>

                    <dt class="col-sm-3">Khách hàng:</dt>
                    <dd class="col-sm-9">@Model.DatLich?.ThuCung?.KhachHang?.HoTen</dd>

                    <dt class="col-sm-3">Số điện thoại:</dt>
                    <dd class="col-sm-9">@Model.DatLich?.ThuCung?.KhachHang?.SoDienThoai</dd>

                    <dt class="col-sm-3">Thú cưng:</dt>
                    <dd class="col-sm-9">@Model.DatLich?.ThuCung?.TenThuCung</dd>

                    <dt class="col-sm-3">Dịch vụ:</dt>
                    <dd class="col-sm-9">@Model.DatLich?.DichVu?.TenDichVu</dd>
                }
                else
                {
                    <dt class="col-sm-3">Tên khách hàng:</dt>
                    <dd class="col-sm-9">@Model.KhachHangTen</dd>

                    <dt class="col-sm-3">Số điện thoại:</dt>
                    <dd class="col-sm-9">@Model.KhachHangSoDienThoai</dd>

                    @if (!string.IsNullOrEmpty(Model.KhachHangEmail))
                    {
                        <dt class="col-sm-3">Email:</dt>
                        <dd class="col-sm-9">@Model.KhachHangEmail</dd>
                    }

                    <dt class="col-sm-3">Dịch vụ:</dt>
                    <dd class="col-sm-9">
                        @Model.TenDichVu
                        @if (!string.IsNullOrEmpty(Model.LoaiDichVu))
                        {
                            <span class="badge bg-secondary ms-1">@Model.LoaiDichVu</span>
                        }
                    </dd>
                }

                <dt class="col-sm-3">Tổng tiền:</dt>
                <dd class="col-sm-9 fw-bold text-success fs-5">@Model.TongTien.ToString("N0") đ</dd>

                <dt class="col-sm-3">Phương thức thanh toán:</dt>
                <dd class="col-sm-9">@(Model.PhuongThucThanhToan ?? "Tiền mặt")</dd>

                @if (!string.IsNullOrEmpty(Model.GhiChu))
                {
                    <dt class="col-sm-3">Ghi chú:</dt>
                    <dd class="col-sm-9">@Model.GhiChu</dd>
                }

                <dt class="col-sm-3">Ngày tạo:</dt>
                <dd class="col-sm-9">@Model.NgayTao.ToString("dd/MM/yyyy HH:mm")</dd>
            </dl>

            <div class="mt-4">
                <a href="@Url.Action("Delete", new { id = Model.Id })" class="btn btn-danger">Xóa</a>
                <a href="@Url.Action("Index")" class="btn btn-secondary">Quay lại</a>
            </div>
        </div>
    </div>
</div>


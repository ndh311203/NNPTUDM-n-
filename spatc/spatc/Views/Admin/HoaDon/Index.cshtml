@model IEnumerable<spatc.Models.HoaDon>
@{
    ViewData["Title"] = "Quản lý Hóa đơn";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Quản lý Hóa đơn</h2>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Tạo hóa đơn mới
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Ngày thanh toán</th>
                            <th>Khách hàng</th>
                            <th>Dịch vụ</th>
                            <th>Tổng tiền</th>
                            <th>Phương thức</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.NgayThanhToan.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (item.LoaiHoaDon == "TuDatLich")
                                    {
                                        <span>@item.DatLich?.ThuCung?.KhachHang?.HoTen</span>
                                        <span class="badge bg-info ms-1">Từ đặt lịch</span>
                                    }
                                    else
                                    {
                                        <span>@item.KhachHangTen</span>
                                        <span class="badge bg-success ms-1">Đến quán</span>
                                    }
                                </td>
                                <td>
                                    @if (item.LoaiHoaDon == "TuDatLich")
                                    {
                                        @item.DatLich?.DichVu?.TenDichVu
                                    }
                                    else
                                    {
                                        @item.TenDichVu
                                        @if (!string.IsNullOrEmpty(item.LoaiDichVu))
                                        {
                                            <span class="badge bg-secondary ms-1">@item.LoaiDichVu</span>
                                        }
                                    }
                                </td>
                                <td class="fw-bold text-success">@item.TongTien.ToString("N0") đ</td>
                                <td>@(item.PhuongThucThanhToan ?? "Tiền mặt")</td>
                                <td>
                                    <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-sm btn-info">
                                        <i class="bi bi-search"></i> Chi tiết
                                    </a>
                                    <a href="@Url.Action("Delete", new { id = item.Id })" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


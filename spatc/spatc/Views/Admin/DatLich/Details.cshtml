@model spatc.Models.DatLich
@{
    ViewData["Title"] = "Chi tiết đặt lịch";
    var nhanViens = ViewBag.NhanVienId as SelectList ?? new SelectList(new List<object>(), "Id", "HoTen");
}

<div class="container mt-4">
    <h2>Chi tiết đặt lịch</h2>
    <hr />

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-4">Thời gian hẹn:</dt>
                <dd class="col-sm-8">@Model.ThoiGianHen.ToString("dd/MM/yyyy HH:mm")</dd>

                <dt class="col-sm-4">Khách hàng:</dt>
                <dd class="col-sm-8">@Model.ThuCung?.KhachHang?.HoTen</dd>

                <dt class="col-sm-4">Số điện thoại:</dt>
                <dd class="col-sm-8">@Model.ThuCung?.KhachHang?.SoDienThoai</dd>

                <dt class="col-sm-4">Thú cưng:</dt>
                <dd class="col-sm-8">@Model.ThuCung?.TenThuCung (@Model.ThuCung?.Loai)</dd>

                <dt class="col-sm-4">Dịch vụ:</dt>
                <dd class="col-sm-8">@Model.DichVu?.TenDichVu - @Model.DichVu?.Gia.ToString("N0") đ</dd>

                <dt class="col-sm-4">Nhân viên:</dt>
                <dd class="col-sm-8">@(Model.NhanVien?.HoTen ?? "Chưa gán")</dd>

                <dt class="col-sm-4">Trạng thái:</dt>
                <dd class="col-sm-8">
                    <span class="badge bg-@(Model.TrangThai == "Chờ" ? "warning" : Model.TrangThai == "Đang làm" ? "info" : Model.TrangThai == "Hoàn thành" ? "success" : "danger")">
                        @Model.TrangThai
                    </span>
                </dd>

                <dt class="col-sm-4">Ghi chú:</dt>
                <dd class="col-sm-8">@(Model.GhiChu ?? "Không có")</dd>

                <dt class="col-sm-4">Ngày tạo:</dt>
                <dd class="col-sm-8">@Model.NgayTao.ToString("dd/MM/yyyy HH:mm")</dd>
            </dl>

            <!-- Form cập nhật trạng thái -->
            <div class="card mt-4">
                <div class="card-header">
                    <h5>Cập nhật trạng thái</h5>
                </div>
                <div class="card-body">
                    <form asp-action="UpdateStatus" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        
                        <div class="mb-3">
                            <label class="form-label">Trạng thái:</label>
                            <select name="trangThai" class="form-select" required>
                                <option value="Chờ" selected="@(Model.TrangThai == "Chờ")">Chờ</option>
                                <option value="Đang làm" selected="@(Model.TrangThai == "Đang làm")">Đang làm</option>
                                <option value="Hoàn thành" selected="@(Model.TrangThai == "Hoàn thành")">Hoàn thành</option>
                                <option value="Hủy" selected="@(Model.TrangThai == "Hủy")">Hủy</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Gán nhân viên:</label>
                            <select name="nhanVienId" class="form-select">
                                <option value="">-- Chọn nhân viên --</option>
                                @foreach (var nv in nhanViens)
                                {
                                    <option value="@nv.Value" selected="@(Model.NhanVienId?.ToString() == nv.Value)">@nv.Text</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Ghi chú:</label>
                            <textarea name="ghiChu" class="form-control" rows="3">@Model.GhiChu</textarea>
                        </div>

                        <button type="submit" class="btn btn-primary">Cập nhật</button>
                    </form>
                </div>
            </div>

            <div class="mt-4">
                <a href="@Url.Action("Index")" class="btn btn-secondary">Quay lại</a>
            </div>
        </div>
    </div>
</div>


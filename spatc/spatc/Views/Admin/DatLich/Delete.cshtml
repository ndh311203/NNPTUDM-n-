@model spatc.Models.DatLich
@{
    ViewData["Title"] = "Xóa đặt lịch";
}

<div class="container mt-4">
    <h2>Xóa đặt lịch</h2>
    <hr />

    <div class="alert alert-warning">
        <strong>Bạn có chắc chắn muốn xóa đặt lịch này?</strong>
    </div>

    <div class="row">
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-3">ID:</dt>
                <dd class="col-sm-9">@Model.Id</dd>

                <dt class="col-sm-3">Thời gian hẹn:</dt>
                <dd class="col-sm-9">@Model.ThoiGianHen.ToString("dd/MM/yyyy HH:mm")</dd>

                <dt class="col-sm-3">Khách hàng:</dt>
                <dd class="col-sm-9">@Model.ThuCung?.KhachHang?.HoTen</dd>

                <dt class="col-sm-3">Thú cưng:</dt>
                <dd class="col-sm-9">@Model.ThuCung?.TenThuCung</dd>

                <dt class="col-sm-3">Dịch vụ:</dt>
                <dd class="col-sm-9">@Model.DichVu?.TenDichVu</dd>

                <dt class="col-sm-3">Trạng thái:</dt>
                <dd class="col-sm-9">@Model.TrangThai</dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <button type="submit" class="btn btn-danger">Xóa</button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>


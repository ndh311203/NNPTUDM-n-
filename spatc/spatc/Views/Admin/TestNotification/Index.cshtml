@model List<spatc.Models.ThongBao>
@{
    ViewData["Title"] = "Test Thông báo";
}

<div class="container mt-4">
    <h2>Test Hệ thống Thông báo</h2>
    <hr />

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5>Tổng thông báo</h5>
                    <h2>@ViewBag.TotalNotifications</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h5>Chưa đọc</h5>
                    <h2>@ViewBag.UnreadNotifications</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h5>Gửi Admin</h5>
                    <h2>@ViewBag.AdminNotifications</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5>Gửi Khách hàng</h5>
                    <h2>@ViewBag.CustomerNotifications</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="mb-3">
        <button type="button" class="btn btn-primary" onclick="createTestNotification()">
            <i class="bi bi-bell"></i> Tạo thông báo test
        </button>
        <a href="@Url.Action("Index", "Admin")" class="btn btn-secondary">Quay lại</a>
    </div>

    <div class="card">
        <div class="card-header">
            <h5>10 Thông báo mới nhất</h5>
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Loại</th>
                            <th>Tiêu đề</th>
                            <th>Nội dung</th>
                            <th>Người nhận</th>
                            <th>Đã đọc</th>
                            <th>Thời gian</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var notif in Model)
                        {
                            <tr class="@(!notif.DaDoc ? "table-warning" : "")">
                                <td>@notif.Id</td>
                                <td><span class="badge bg-secondary">@notif.LoaiThongBao</span></td>
                                <td>@notif.TieuDe</td>
                                <td>@(notif.NoiDung.Length > 50 ? notif.NoiDung.Substring(0, 50) + "..." : notif.NoiDung)</td>
                                <td>@(notif.NguoiNhanId.HasValue ? $"User {notif.NguoiNhanId}" : "Admin")</td>
                                <td>@(notif.DaDoc ? "✓" : "✗")</td>
                                <td>@notif.ThoiGianTao.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted">Chưa có thông báo nào</p>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function createTestNotification() {
            fetch('/Admin/TestNotification/CreateTest', {
                method: 'POST',
                headers: {
                    'Accept': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Đã tạo thông báo test thành công! ID: ' + data.notificationId);
                    location.reload();
                } else {
                    alert('Lỗi: ' + data.message);
                    console.error('Error:', data);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Có lỗi xảy ra');
            });
        }
    </script>
}


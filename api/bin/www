#!/usr/bin/env node

/**
 * Module dependencies.
 */
const http = require('http');
const app = require('../app');
const { Server } = require('socket.io');

/**
 * Get port from environment and store in Express.
 */
const port = normalizePort(process.env.PORT || '3000');
app.set('port', port);

/**
 * Create HTTP server.
 */
const server = http.createServer(app);

/**
 * Initialize Socket.IO for real-time features
 */
const io = new Server(server, {
  cors: {
    origin: process.env.API_URL || 'http://localhost:3000',
    methods: ['GET', 'POST']
  }
});

// Make io accessible to app
app.set('io', io);

// Xử lý các sự kiện Socket.IO
io.on('connection', (socket) => {
  console.log(`[Socket] Client kết nối: ${socket.id}`);

  // Client tham gia vào phòng chat
  socket.on('join_room', (room) => {
    socket.join(room);
    console.log(`[Socket] ${socket.id} tham gia phòng: ${room}`);
    socket.emit('joined_room', { room, message: `Đã tham gia phòng ${room}` });
  });

  // Client tham gia vào kênh thông báo riêng
  socket.on('join_user', (userId) => {
    socket.join(`user_${userId}`);
    console.log(`[Socket] ${socket.id} đăng ký nhận thông báo user: ${userId}`);
  });

  // Client gửi tin nhắn trực tiếp qua socket (không qua API)
  socket.on('send_message', (data) => {
    const msg = {
      ...data,
      _id: Date.now().toString(),
      createdAt: new Date(),
    };
    io.to(data.room || 'general').emit('new_message', msg);
  });

  socket.on('disconnect', () => {
    console.log(`[Socket] Client ngắt kết nối: ${socket.id}`);
  });
});

/**
 * Listen on provided port, on all network interfaces.
 */
server.listen(port, () => {
  console.log(`
  ╔════════════════════════════════════════╗
  ║   SPATC Pet Shop API Server Started    ║
  ║   Environment: ${process.env.NODE_ENV || 'development'}${' '.repeat(25 - (process.env.NODE_ENV || 'development').length)}║
  ║   Port: ${port}${' '.repeat(33 - port.toString().length)}║
  ║   URL: http://localhost:${port}${' '.repeat(21 - port.toString().length)}║
  ╚════════════════════════════════════════╝
  `);
});

/**
 * Normalize a port into a number, string, or false.
 */
function normalizePort(val) {
  const port = parseInt(val, 10);

  if (isNaN(port)) {
    // named pipe
    return val;
  }

  if (port >= 0) {
    // port number
    return port;
  }

  return false;
}

/**
 * Event listener for HTTP server "error" event.
 */
server.on('error', (error) => {
  if (error.syscall !== 'listen') {
    throw error;
  }

  const bind = typeof port === 'string'
    ? 'Pipe ' + port
    : 'Port ' + port;

  // handle specific listen errors with friendly messages
  switch (error.code) {
    case 'EACCES':
      console.error(bind + ' requires elevated privileges');
      process.exit(1);
      break;
    case 'EADDRINUSE':
      console.error(bind + ' is already in use');
      process.exit(1);
      break;
    default:
      throw error;
  }
});

/**
 * Event listener for HTTP server "listening" event.
 */
server.on('listening', () => {
  const addr = server.address();
  const bind = typeof addr === 'string'
    ? 'pipe ' + addr
    : 'port ' + addr.port;
  console.log('Listening on ' + bind);
});

// Handle graceful shutdown
process.on('SIGINT', () => {
  console.log('\nShutting down gracefully...');
  server.close(() => {
    console.log('Server closed');
    process.exit(0);
  });
});

module.exports = server;

#App Configuration
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Database Configuration - MongoDB
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/spatc

# Cloud MongoDB (Atlas) - uncomment to use
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/spatc?retryWrites=true&w=majority

MONGODB_USER=
MONGODB_PASSWORD=

# JWT Configuration
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=change-this-refresh-token-secret-in-production
REFRESH_TOKEN_EXPIRE=30d

# OAuth Configuration (Google)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# OAuth Configuration (Facebook)
FACEBOOK_APP_ID=YOUR_FACEBOOK_APP_ID
FACEBOOK_APP_SECRET=YOUR_FACEBOOK_APP_SECRET
FACEBOOK_CALLBACK_URL=http://localhost:3000/auth/facebook/callback

# File Upload Configuration
MAX_FILE_SIZE=52428800
UPLOAD_PATH=./uploads

# VietQR Payment Configuration
VIETQR_BANK_NAME=MB Bank
VIETQR_ACCOUNT_NUMBER=0842609749
VIETQR_ACCOUNT_NAME=NGUYEN DUC HUY
VIETQR_TEMPLATE=compact2

# Email Configuration (for notifications, password reset, etc.)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@spatc.com

# Admin Configuration
ADMIN_EMAIL=admin@spatc.com
ADMIN_PASSWORD=change-this-password-in-production

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs

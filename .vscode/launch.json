{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "🌐 Frontend (http-server port 8080)",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}/frontend"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "🚀 API (nodemon port 3000)",
            "cwd": "${workspaceFolder}/api",
            "runtimeExecutable": "npx",
            "runtimeArgs": ["nodemon", "bin/www"],
            "console": "integratedTerminal",
            "restart": true,
            "env": {
                "NODE_ENV": "development"
            },
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "🚀 API (node port 3000)",
            "cwd": "${workspaceFolder}/api",
            "runtimeExecutable": "node",
            "runtimeArgs": ["bin/www"],
            "console": "integratedTerminal",
            "env": {
                "NODE_ENV": "development"
            },
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "type": "node",
            "request": "attach",
            "name": "🔴 Attach to API (port 3000)",
            "port": 3000,
            "restart": true,
            "skipFiles": ["<node_internals>/**"]
        }
    ],
    "compounds": [
        {
            "name": "⚡ Full Stack (API + Frontend)",
            "configurations": ["🚀 API (nodemon port 3000)", "🌐 Frontend (http-server port 8080)"]
        }
    ]
}
